<%= h3_with_anchor "Icon Recommendations" %>

<pre><code class="language-typescript">// Suggest alternative icons for better UX
async function suggestAlternatives(currentIcon: string) {
    const result = await searchIconsTool.invoke({
        queries: [`similar to ${currentIcon}`, currentIcon],
        limit: 8
    });
    
    // Remove the current icon from suggestions
    const alternatives = result.results[currentIcon]
        .filter(icon => icon !== currentIcon);
    
    return alternatives;
}</code></pre>

<%= h2_with_anchor "Troubleshooting" %>

<%= h3_with_anchor "Common Issues" %>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Issue</th>
            <th>Cause</th>
            <th>Solution</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>No results returned</td>
            <td>Query too specific or unrelated</td>
            <td>Use broader terms or break into concepts</td>
        </tr>
        <tr>
            <td>Unexpected icons</td>
            <td>Ambiguous query terms</td>
            <td>Add context or use more specific descriptions</td>
        </tr>
        <tr>
            <td>Slow performance</td>
            <td>Cold cache or many queries</td>
            <td>Batch queries, increase cache TTL</td>
        </tr>
        <tr>
            <td>Duplicate results</td>
            <td>Similar queries</td>
            <td>Deduplicate on client side or use distinct queries</td>
        </tr>
    </tbody>
</table>

