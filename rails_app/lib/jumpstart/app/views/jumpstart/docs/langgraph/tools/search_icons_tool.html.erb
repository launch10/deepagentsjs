//   "save document": ["save", "file-text", "download"],
//   "delete item": ["trash-2", "x", "delete"],
//   "user profile": ["user", "user-circle", "contact"]
// }</code></pre>

<%= h3_with_anchor "Visual Description Queries" %>

<pre><code class="language-typescript">// Find icons based on visual appearance
