<%= h2_with_anchor "Advanced Usage" %>

<%= h3_with_anchor "Custom Service Configuration" %>

<p>For advanced use cases, you can directly use the underlying service:</p>

<pre><code class="language-typescript">import { SearchIconsService } from "@services/searchIcons";

const service = new SearchIconsService({
    cacheOptions: {
        ttlHours: 168,  // Cache for 1 week
        minSimilarity: 0.3  // Lower threshold for broader matches
    }
});

// Direct service usage
const results = await service.searchIcons(
    ["minimalist arrow"],
    { topK: 10 }
);</code></pre>

<%= h3_with_anchor "Batch Processing" %>

<pre><code class="language-typescript">// Process icon requirements for multiple UI components
const uiComponents = [
    { name: "Header", needs: ["menu", "search", "user profile"] },
    { name: "Sidebar", needs: ["dashboard", "settings", "logout"] },
    { name: "Toolbar", needs: ["save", "undo", "redo", "print"] }
];

const iconSuggestions = await Promise.all(
    uiComponents.map(async (component) => {
        const result = await searchIconsTool.invoke({
            queries: component.needs,
            limit: 3
        });
        return {
            component: component.name,
            icons: result.results
        };
    })
);</code></pre>

<%= h2_with_anchor "Testing" %>

<%= h3_with_anchor "Unit Testing" %>

<pre><code class="language-typescript">import { vi, describe, it, expect } from 'vitest';
import { SearchIconsTool } from '@tools/searchIcons';

describe('SearchIconsTool', () => {
    it('should find navigation icons', async () => {
        const tool = new SearchIconsTool();
        const result = await tool.invoke({
            queries: ["navigation menu"],
            limit: 5
        });
        
        expect(result.results["navigation menu"]).toContain("menu");
        expect(result.results["navigation menu"].length).toBeLessThanOrEqual(5);
    });
    
    it('should handle multiple queries', async () => {
        const tool = new SearchIconsTool();
        const result = await tool.invoke({
            queries: ["save", "delete", "edit"],
            limit: 3
        });
        
        expect(Object.keys(result.results)).toHaveLength(3);
        expect(result.results["save"]).toContain("save");
        expect(result.results["delete"]).toContainAnyOf(["trash", "trash-2", "x"]);
    });
});</code></pre>

