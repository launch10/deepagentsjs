<%= h2_with_anchor "Building on PostgresEmbeddingsService" %>

<p>This service is designed to be extended for specific use cases. Here are examples of services built on top of it:</p>

<%= h3_with_anchor "Example: Icon Search Service" %>

<pre><code class="language-typescript">class SearchIconsService {
    private embeddingsService: PostgresEmbeddingsService;
    
    constructor() {
        this.embeddingsService = new PostgresEmbeddingsService({
            tableName: "lucide_icons",
            cacheOptions: { ttlHours: 168 }  // Cache for 1 week
        });
    }
    
    async indexIcons(icons: IconData[]) {
        const embeddings = icons.map(icon => ({
            pageContent: `${icon.name} ${icon.tags.join(' ')}`,
            metadata: { 
                name: icon.name,
                category: icon.category 
            }
        }));
        
        await this.embeddingsService.storeEmbeddings(embeddings);
    }
    
    async searchIcons(query: string, limit: number = 5) {
        return await this.embeddingsService.search(query, limit);
    }
}</code></pre>

<%= h3_with_anchor "Example: Code Search Service" %>

<pre><code class="language-typescript">class CodeSearchService {
    private embeddingsService: PostgresEmbeddingsService;
    
    constructor() {
        this.embeddingsService = new PostgresEmbeddingsService({
            tableName: "code_files",
            embeddingModel: "text-embedding-3-large",  // Better model for code
            embeddingDimensions: 3072
        });
    }
    
    async indexCodebase(files: CodeFile[]) {
        const embeddings = files.map(file => ({
            pageContent: file.content,
            metadata: { 
                path: file.path,
                language: file.language,
                lastModified: file.lastModified 
            }
        }));
        
        await this.embeddingsService.storeEmbeddings(embeddings);
    }
    
    async findSimilarCode(snippet: string) {
        return await this.embeddingsService.search(snippet, 10, {
            filter: { language: "typescript" }  // Filter by language
        });
    }
}</code></pre>

<%= h2_with_anchor "Performance Considerations" %>

<%= h3_with_anchor "Optimization Tips" %>

<ol>
    <li><strong>Use Multi-Query Search</strong>: When searching for multiple items, use <code>multiQuerySearch()</code> instead of multiple individual searches</li>
    <li><strong>Configure Appropriate Cache TTL</strong>: Longer TTL for stable content, shorter for frequently changing data</li>
    <li><strong>Index Strategically</strong>: Only index searchable content, not entire documents</li>
    <li><strong>Use Metadata Filters</strong>: Narrow search space with metadata filters when possible</li>
</ol>

<%= h3_with_anchor "Scaling Guidelines" %>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Dataset Size</th>
            <th>Recommended Approach</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>&lt; 10,000 documents</td>
            <td>Standard configuration works well</td>
        </tr>
        <tr>
            <td>10,000 - 100,000 documents</td>
            <td>Consider increasing cache TTL, use metadata filters extensively</td>
        </tr>
        <tr>
            <td>100,000 - 1M documents</td>
            <td>Implement partitioning by metadata, consider dedicated read replicas</td>
        </tr>
        <tr>
            <td>&gt; 1M documents</td>
            <td>Consider specialized vector databases, implement sharding</td>
        </tr>
    </tbody>
</table>

<%= h2_with_anchor "Error Handling" %>

<p>The service includes comprehensive error handling:</p>

<pre><code class="language-typescript">try {
    const results = await embeddingsService.search("query", 5);
} catch (error) {
    if (error.code === 'ECONNREFUSED') {
        // Database connection issue
    } else if (error.message.includes('dimension')) {
        // Embedding dimension mismatch
    } else if (error.message.includes('rate_limit')) {
        // OpenAI rate limiting
    }
}</code></pre>

