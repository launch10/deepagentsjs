        </tr>
        <tr>
            <td>Poor relevance ranking</td>
            <td>Generic terms or stopwords</td>
            <td>Use more specific terms, adjust query</td>
        </tr>
        <tr>
            <td>Slow searches</td>
            <td>Missing indexes or large result sets</td>
            <td>Check indexes, reduce limit, optimize query</td>
        </tr>
        <tr>
            <td>Boolean syntax errors</td>
            <td>Invalid operators or syntax</td>
            <td>Check operator syntax (&, |, !), balance parentheses</td>
        </tr>
        <tr>
            <td>Partial matches missing</td>
            <td>Using phrase mode instead of plain</td>
            <td>Switch to plain mode for partial matching</td>
        </tr>
    </tbody>
</table>

