<%= h2_with_anchor "Testing" %>

<%= h3_with_anchor "Unit Tests" %>

<pre><code class="language-typescript">import { describe, it, expect } from 'vitest';
import { SearchFilesTool } from '@tools/searchFiles';

describe('SearchFilesTool', () => {
    const tool = new SearchFilesTool();
    
    it('should find files by content', async () => {
        const result = await tool.invoke({
            searches: [{
                content: "function",
                limit: 5
            }]
        });
        
        expect(result.results[0].files).toBeDefined();
        expect(result.results[0].files.length).toBeLessThanOrEqual(5);
    });
    
    it('should handle boolean queries', async () => {
        const result = await tool.invoke({
            searches: [{
                content: "async & function & !deprecated",
                searchMode: "boolean",
                limit: 3
            }]
        });
        
        const files = result.results[0].files;
        files.forEach(file => {
            expect(file.content).toContain('async');
            expect(file.content).toContain('function');
            expect(file.content).not.toContain('deprecated');
        });
    });
    
    it('should search by path pattern', async () => {
        const result = await tool.invoke({
            searches: [{
                path: "test",
                limit: 10
            }]
        });
        
        result.results[0].files.forEach(file => {
            expect(file.path.toLowerCase()).toContain('test');
        });
    });
});</code></pre>

