<%= h2_with_anchor "Troubleshooting" %>

<%= h3_with_anchor "Common Issues" %>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Issue</th>
            <th>Cause</th>
            <th>Solution</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>No results found</td>
            <td>Terms not in index or too specific</td>
