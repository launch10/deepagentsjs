# Full stack with all services
# Ports configured via config/services.sh (RAILS_PORT, LANGGRAPH_PORT)
# Environment variables (LANGGRAPH_API_URL, etc.) come from .env or .env.test via dotenv
web: bundle exec rails server -p ${RAILS_PORT:-3000}
vite: VITE_RAILS_API_URL=${VITE_RAILS_API_URL:-http://localhost:3000} VITE_LANGGRAPH_API_URL=${VITE_LANGGRAPH_API_URL:-http://localhost:4000} bin/vite dev --mode ${RAILS_ENV:-development}
langgraph: cd ../langgraph_app && PORT=${LANGGRAPH_PORT:-4000} RAILS_API_URL=${RAILS_API_URL:-http://localhost:3000} pnpm run dev
bullmq: cd ../langgraph_app && pnpm run worker:dev
worker: bundle exec sidekiq
zhong: bundle exec zhong schedule.rb
stripe: bin/stripe-listen
