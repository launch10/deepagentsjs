  "scripts": {
    "build": "vite build",
    "check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:cleanup && playwright test",
    "test:e2e:cleanup": "LAUNCH10_ENV=test ../bin/services cleanup",
    "test:e2e:ui": "npm run test:e2e:cleanup && playwright test --ui",
    "test:e2e:headed": "npm run test:e2e:cleanup && playwright test --headed",
    "test:e2e:debug": "npm run test:e2e:cleanup && playwright test --debug",
    "playwright:install": "playwright install chromium",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
