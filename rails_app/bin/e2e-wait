#!/usr/bin/env bash
# Wait for test services to be ready before running Playwright tests.
# Used by test:e2e:start in package.json.

set -e

# Use ports from config/services.sh (auto-set by bin/dev-test)
RAILS_URL="${RAILS_API_URL:-http://localhost:${RAILS_PORT:-3001}}"
LANGGRAPH_URL="${LANGGRAPH_API_URL:-http://localhost:${LANGGRAPH_PORT:-4001}}"
MAX_ATTEMPTS=60

echo "[e2e-wait] Waiting for Rails on $RAILS_URL..."

for ((i=1; i<=MAX_ATTEMPTS; i++)); do
  if curl -sf "$RAILS_URL/up" >/dev/null 2>&1; then
    echo "[e2e-wait] Rails ready."
    break
  fi
  if [ "$i" -eq "$MAX_ATTEMPTS" ]; then
    echo "[e2e-wait] Rails failed to start within ${MAX_ATTEMPTS}s" >&2
    exit 1
  fi
  sleep 1
done

echo "[e2e-wait] Waiting for Langgraph on $LANGGRAPH_URL..."

for ((i=1; i<=MAX_ATTEMPTS; i++)); do
  if curl -sf "$LANGGRAPH_URL/health" >/dev/null 2>&1; then
    echo "[e2e-wait] Langgraph ready."
    break
  fi
  if [ "$i" -eq "$MAX_ATTEMPTS" ]; then
    echo "[e2e-wait] Langgraph failed to start within ${MAX_ATTEMPTS}s" >&2
    echo "[e2e-wait] Check logs: OVERMIND_SOCKET=.overmind-test.sock overmind echo langgraph" >&2
    exit 1
  fi
  sleep 1
done

echo "[e2e-wait] All services ready."
