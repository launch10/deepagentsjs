{
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["vite/client"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ESNext",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/javascript/frontend/*"],
      "@api/*": ["./app/javascript/frontend/api/*"],
      "@components/*": ["./app/javascript/frontend/components/*"],
      "@context/*": ["./app/javascript/frontend/context/*"],
      "@hooks/*": ["./app/javascript/frontend/hooks/*"],
      "@stores/*": ["./app/javascript/frontend/stores/*"],
      "@lib/*": ["./app/javascript/frontend/lib/*"],
      "@models/*": ["./app/javascript/frontend/shared/models/*"],
      "@utils/*": ["./app/javascript/frontend/lib/utils/*"],
      "@runtime/*": ["./app/javascript/frontend/runtime/*"],
      "types/*": ["./app/javascript/frontend/types/*"],
      "@rails_api_base": ["../shared/lib/api/index.ts"],
      "@styles/*": ["./app/javascript/frontend/styles/*"],
      "@webcontainer/*": ["./app/javascript/frontend/webcontainer/*"],
      "@shared": ["../shared/index.ts"],
      "@pages/*": ["./app/javascript/frontend/pages/*"],
      "@helpers/*": ["./app/javascript/frontend/helpers/*"],
      "@assets/*": ["./app/javascript/assets/*"]
    },
    "noEmit": true,
    "incremental": true
  },
  "include": ["**/*.ts", "**/*.tsx", "vite.config.ts", "postcss.config.js"],
  "exclude": ["node_modules", "public", "vendor", "app/javascript/frontend_old", "templates"]
}
