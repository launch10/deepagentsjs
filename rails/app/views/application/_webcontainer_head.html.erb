<title>
  <% if content_for?(:title) %>
    <%= yield :title %> |
  <% end %>
  <%= Jumpstart.config.application_name %>
</title>

<%= csrf_meta_tags %>
<%= csp_meta_tag %>
<%= viewport_meta_tag %>
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="<%= Jumpstart.config.application_name %>">

<% if current_user&.system_theme? %>
  <script>document.documentElement.classList.toggle("dark", window.matchMedia('(prefers-color-scheme: dark)').matches)</script>
<% end %>
<%= javascript_importmap_tags %>
<%= stylesheet_link_tag "tailwind", media: "all", "data-turbo-track": "reload" %>

<%= render "favicons" %>

<%= yield :head %>