@@ -2,8 +2,9 @@ import { createMiddleware } from "../middleware.js";
 import "../index.js";
 import { AIMessage, ToolMessage } from "@langchain/core/messages";
 import { tool } from "@langchain/core/tools";
-import { Command } from "@langchain/langgraph";
+import { Command, StateSchema, ReducedValue } from "@langchain/langgraph";
 import { z } from "zod/v3";
+import { randomUUID } from "crypto";
 
 //#region src/agents/middleware/todoListMiddleware.ts
 /**
@@ -242,10 +243,33 @@ const TodoStatus = z.enum([
 	"completed"
 ]).describe("Status of the todo");
 const TodoSchema = z.object({
+	id: z.string().optional().describe("Unique identifier for the todo"),
 	content: z.string().describe("Content of the todo item"),
 	status: TodoStatus
 });
-const stateSchema = z.object({ todos: z.array(TodoSchema).default([]) });
+function todosReducer(current, update) {
+	if (!update) return current || [];
+	if (!current || current.length === 0) return update;
+	const STATUS_PRIORITY = { pending: 0, in_progress: 1, completed: 2 };
+	const merged = [...current];
+	const mergedById = new Map(merged.map((t, i) => [t.id, i]));
+	for (const todo of update) {
+		const existingIdx = mergedById.get(todo.id);
+		if (existingIdx !== undefined) {
+			const prev = merged[existingIdx];
+			const prevPriority = STATUS_PRIORITY[prev.status] ?? 0;
+			const nextPriority = STATUS_PRIORITY[todo.status] ?? 0;
+			if (nextPriority >= prevPriority) {
+				merged[existingIdx] = todo;
+			}
+		} else {
+			mergedById.set(todo.id, merged.length);
+			merged.push(todo);
+		}
+	}
+	return merged;
+}
+const stateSchema = new StateSchema({ todos: new ReducedValue(z.array(TodoSchema).default([]), { reducer: todosReducer }) });
 /**
 * Creates a middleware that provides todo list management capabilities to agents.
 *
@@ -286,10 +310,19 @@ function todoListMiddleware(options) {
 	* Write todos tool - manages todo list with Command return
 	*/
 	const writeTodos = tool(({ todos }, config) => {
+		const todosWithIds = todos.map((t) => ({
+			...t,
+			id: t.id || randomUUID(),
+		}));
+		console.debug("[todoListMiddleware] write_todos called", {
+			count: todosWithIds.length,
+			ids: todosWithIds.map((t) => t.id),
+			statuses: todosWithIds.map((t) => `${t.id.slice(0, 8)}:${t.status}`),
+		});
 		return new Command({ update: {
-			todos,
+			todos: todosWithIds,
 			messages: [new ToolMessage({
-				content: `Updated todo list to ${JSON.stringify(todos)}`,
+				content: `Updated todo list to ${JSON.stringify(todosWithIds)}`,
 				tool_call_id: config.toolCall?.id
 			})]
 		} });
