{
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "types": [
      "@remix-run/cloudflare",
      "vite/client",
      "@cloudflare/workers-types/2023-07-01"
    ],
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ESNext",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./app/*",
        "./db/*"
      ],
      "@schemas/*": [
        "./app/lib/.server/langgraph/schemas/*"
      ],
      "@prompts/*": [
        "./app/lib/.server/langgraph/prompts/*"
      ],
      "@nodes/*": [
        "./app/lib/.server/langgraph/nodes/*"
      ],
      "@graphs/*": [
        "./app/lib/.server/langgraph/graphs/*"
      ],
      "@state/*": [
        "./app/lib/.server/langgraph/state/*"
      ],
      "@services/*": [
        "./app/lib/.server/langgraph/services/*"
      ],
      "@utils/*": [
        "./app/lib/.server/langgraph/utils/*"
      ],
      "@tools/*": [
        "./app/lib/.server/langgraph/tools/*"
      ],
      "@langgraph/*": [
        "./app/lib/.server/langgraph/*"
      ],
      "@shared/*": [
        "./app/lib/shared/*"
      ],
      "@models/*": [
        "./app/lib/shared/models/*"
      ],
      "@db/*": [
        "./db/*"
      ],
      "@db": [
        "./db/index.ts"
      ],
      "@lib/*": [
        "./app/lib/*"
      ]
    },
    // vite takes care of building everything, not tsc
    "noEmit": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/.client/**/*.ts",
    "**/.client/**/*.tsx",
    "**/.server/**/*.ts",
    "**/.server/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
