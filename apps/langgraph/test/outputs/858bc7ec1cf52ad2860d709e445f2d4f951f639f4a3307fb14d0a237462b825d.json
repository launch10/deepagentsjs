 p-6\">\n          <h"},{"type":"text-delta","textDelta":"1 className=\"text-3xl font-"},{"type":"text-delta","textDelta":"bold text-center mb-6 text-"},{"type":"text-delta","textDelta":"green-700\">Il Mio To"},{"type":"text-delta","textDelta":"do Italiano</h1>\n          <TodoList"},{"type":"text-delta","textDelta":" />\n        </div>\n      "},{"type":"text-delta","textDelta":"</div>\n      <Toaster />"},{"type":"text-delta","textDelta":"\n    </ThemeProvider>\n  );"},{"type":"text-delta","textDelta":"\n}\n\nexport default App;\n</gen"},{"type":"text-delta","textDelta":"-write>\n\nNow, let's create our"},{"type":"text-delta","textDelta":" TodoList component:\n\n<gen-write fil"},{"type":"text-delta","textDelta":"ePath=\"src/components/TodoList.jsx"},{"type":"text-delta","textDelta":"\">\nimport React, { useState }"},{"type":"text-delta","textDelta":" from 'react';\nimport { Input"},{"type":"text-delta","textDelta":" } from './ui/input';\nimport {"},{"type":"text-delta","textDelta":" Button } from './ui/button';\nimport"},{"type":"text-delta","textDelta":" { useToast } from './ui"},{"type":"text-delta","textDelta":"/use-toast';\nimport { Pizza"},{"type":"text-delta","textDelta":", Spaghetti, Coffee"},{"type":"text-delta","textDelta":" } from 'lucide-react';"},{"type":"text-delta","textDelta":"\n\nexport function TodoList() {\n  const [todos"},{"type":"text-delta","textDelta":", setTodos] = useState([]);"},{"type":"text-delta","textDelta":"\n  const [newTodo, setNewT"},{"type":"text-delta","textDelta":"odo] = useState('');\n  const {"},{"type":"text-delta","textDelta":" toast } = useToast();\n\n  const ad"},{"type":"text-delta","textDelta":"dTodo = () => {\n    if ("},{"type":"text-delta","textDelta":"newTodo.trim()) {\n      set"},{"type":"text-delta","textDelta":"Todos([...todos, { text"},{"type":"text-delta","textDelta":": newTodo, completed: false }]);"},{"type":"text-delta","textDelta":"\n      setNewTodo('');\n      "},{"type":"text-delta","textDelta":"toast({\n        title: \""},{"type":"text-delta","textDelta":"Bellissimo!\","},{"type":"text-delta","textDelta":"\n        description: \"Nuovo comp"},{"type":"text-delta","textDelta":"ito aggiunto con successo!\","},{"type":"text-delta","textDelta":"\n      });\n    }\n  };\n\n  const"},{"type":"text-delta","textDelta":" toggleTodo = (index) => {"},{"type":"text-delta","textDelta":"\n    const newTodos = [...todos];"},{"type":"text-delta","textDelta":"\n    newTodos[index].completed = !"},{"type":"text-delta","textDelta":"newTodos[index].completed;\n    "},{"type":"text-delta","textDelta":"setTodos(newTodos);\n  "},{"type":"text-delta","textDelta":"};\n\n  const getRandomIcon = () => {"},{"type":"text-delta","textDelta":"\n    const icons = [Pizza, Spa"},{"type":"text-delta","textDelta":"ghetti, Coffee];\n    return icons["},{"type":"text-delta","textDelta":"Math.floor(Math.random() * icons"},{"type":"text-delta","textDelta":".length)];\n  };\n\n  return"},{"type":"text-delta","textDelta":" (\n    <div>\n      <div"},{"type":"text-delta","textDelta":" className=\"flex space-x-2 "},{"type":"text-delta","textDelta":"mb-4\">\n        <Input\n          "},{"type":"text-delta","textDelta":"type=\"text\"\n          placeholder"},{"type":"text-delta","textDelta":"=\"Aggiungi un nuovo compito...\""},{"type":"text-delta","textDelta":"\n          value={newTodo}\n          "},{"type":"text-delta","textDelta":"onChange={(e) => setNewTodo("},{"type":"text-delta","textDelta":"e.target.value)}\n          className=\""},{"type":"text-delta","textDelta":"flex-grow\"\n        />\n        "},{"type":"text-delta","textDelta":"<Button onClick={addTodo}>"},{"type":"text-delta","textDelta":"Aggiungi</Button>\n      </div"},{"type":"text-delta","textDelta":">\n      <ul className=\"space"},{"type":"text-delta","textDelta":"-y-2\">\n        {todos."},{"type":"text-delta","textDelta":"map((todo, index) => {"},{"type":"text-delta","textDelta":"\n          const Icon = getRandomIcon();\n          return ("},{"type":"text-delta","textDelta":"\n            <li\n              key={index}"},{"type":"text-delta","textDelta":"\n              className={`flex items-center"},{"type":"text-delta","textDelta":" space-x-2 p-2 rounde"},{"type":"text-delta","textDelta":"d ${\n                todo.completed ? 'bg-"},{"type":"text-delta","textDelta":"green-100' : 'bg-re"},{"type":"text-delta","textDelta":"d-100'\n              }`}\n              "},{"type":"text-delta","textDelta":"onClick={() => toggleTodo(index)}"},{"type":"text-delta","textDelta":"\n            >\n              <Icon className=\"w-"},{"type":"text-delta","textDelta":"5 h-5\" />\n              <span"},{"type":"text-delta","textDelta":" className={todo.completed ? '"},{"type":"text-delta","textDelta":"line-through' : ''}>{todo.text"},{"type":"text-delta","textDelta":"}</span>\n            </li>\n          "},{"type":"text-delta","textDelta":");\n        })}\n      </ul>"},{"type":"text-delta","textDelta":"\n    </div>\n  );\n}"},{"type":"text-delta","textDelta":"\n</gen-write>\n\nLet"},{"type":"text-delta","textDelta":"'s add an Italian flag background image"},{"type":"text-delta","textDelta":":\n\n<gen-write filePath=\"public"},{"type":"text-delta","textDelta":"/images/italian-flag.png\">"},{"type":"text-delta","textDelta":"\n// This is a placeholder for the Italian flag image."},{"type":"text-delta","textDelta":"\n// You should upload an actual image"},{"type":"text-delta","textDelta":" file named 'italian-flag."},{"type":"text-delta","textDelta":"png' to the public/images directory."},{"type":"text-delta","textDelta":"\n</gen-write>\n\nNow, let's"},{"type":"text-delta","textDelta":" update the index.html to set an"},{"type":"text-delta","textDelta":" Italian title:\n\n<gen-"},{"type":"text-delta","textDelta":"write filePath=\"index.html\">\n<!"},{"type":"text-delta","textDelta":"DOCTYPE html>\n<html lang=\"it\">"},{"type":"text-delta","textDelta":"\n  <head>\n    "},{"type":"text-delta","textDelta":"<meta charset=\"UTF-8\" />"},{"type":"text-delta","textDelta":"\n    <link rel=\"icon\" type"},{"type":"text-delta","textDelta":"=\"image/svg+xml\" href=\"/v"},{"type":"text-delta","textDelta":"ite.svg\" />\n    <meta name"},{"type":"text-delta","textDelta":"=\"viewport\" content=\"width=device-width"},{"type":"text-delta","textDelta":", initial-scale=1.0\" />"},{"type":"text-delta","textDelta":"\n    <title>Il Mio To"},{"type":"text-delta","textDelta":"do Italiano</title>\n  </head>"},{"type":"text-delta","textDelta":"\n  <body>\n    <div i"},{"type":"text-delta","textDelta":"d=\"root\"></div>\n    <script type=\"module"},{"type":"text-delta","textDelta":"\" src=\"/src/main.jsx\"></script"},{"type":"text-delta","textDelta":">\n  </body>\n</html>"},{"type":"text-delta","textDelta":"\n</gen-write>\n\n"},{"type":"text-delta","textDelta":"</gen-code>\n\nEcc"},{"type":"text-delta","textDelta":"ellente! I've created a very Italian"},{"type":"text-delta","textDelta":"-themed todo application for you. The"},{"type":"text-delta","textDelta":" app features an Italian flag background, Italian"},{"type":"text-delta","textDelta":" text, and even uses pizza, spaghetti"},{"type":"text-delta","textDelta":", and coffee icons for the todo items. Remember"},{"type":"text-delta","textDelta":" to upload an actual Italian flag image to"},{"type":"text-delta","textDelta":" the public/images directory for the background."},{"type":"finish","finishReason":"stop","usage":{"promptTokens":2729,"completionTokens":1300}}]