    }\n  }\n\n  const"},{"type":"text-delta","textDelta":" toggleTodo = (id) => {"},{"type":"text-delta","textDelta":"\n    setTodos(todos.map(to"},{"type":"text-delta","textDelta":"do =>\n      todo.id === id ? { ..."},{"type":"text-delta","textDelta":"todo, completed: !todo.completed } :"},{"type":"text-delta","textDelta":" todo\n    ))\n  }\n\n  const"},{"type":"text-delta","textDelta":" deleteTodo = (id) => {\n    "},{"type":"text-delta","textDelta":"setTodos(todos.filter(todo =>"},{"type":"text-delta","textDelta":" todo.id !== id))\n  }"},{"type":"text-delta","textDelta":"\n\n  return (\n    <div className=\"bg"},{"type":"text-delta","textDelta":"-white p-6 rounded-lg shadow"},{"type":"text-delta","textDelta":"-md max-w-md mx"},{"type":"text-delta","textDelta":"-auto border-2 border-"},{"type":"text-delta","textDelta":"green-500\">\n      <div"},{"type":"text-delta","textDelta":" className=\"flex mb-4\">\n        "},{"type":"text-delta","textDelta":"<Input\n          type=\"text\"\n          "},{"type":"text-delta","textDelta":"value={newTodo}\n          onChange={("},{"type":"text-delta","textDelta":"e) => setNewTodo(e."},{"type":"text-delta","textDelta":"target.value)}\n          placeholder=\"Agg"},{"type":"text-delta","textDelta":"iungi un compito...\""},{"type":"text-delta","textDelta":"\n          className=\"flex-grow mr-2"},{"type":"text-delta","textDelta":" border-green-300\"\n        />\n        "},{"type":"text-delta","textDelta":"<Button onClick={addTodo} className=\""},{"type":"text-delta","textDelta":"bg-green-500 hover"},{"type":"text-delta","textDelta":":bg-green-600\">\n          "},{"type":"text-delta","textDelta":"<Plus size={20} />\n        </Button>"},{"type":"text-delta","textDelta":"\n      </div>\n      <ul className"},{"type":"text-delta","textDelta":"=\"space-y-2\">"},{"type":"text-delta","textDelta":"\n        {todos.map(todo => ("},{"type":"text-delta","textDelta":"\n          <TodoItem\n            key={to"},{"type":"text-delta","te