#!/usr/bin/env bash

# Launch10 Tunnel Script
# Uses Foreman/Overmind to manage all services + Cloudflare tunnels.
# Clean output, proper process management, easy cleanup with Ctrl+C.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

cleanup() {
    log_info "Cleaning up..."

    # Restore .env files
    if [ -f "$PROJECT_ROOT/rails_app/.env.backup" ]; then
        mv "$PROJECT_ROOT/rails_app/.env.backup" "$PROJECT_ROOT/rails_app/.env"
        log_info "Restored rails_app/.env"
    fi
    if [ -f "$PROJECT_ROOT/langgraph_app/.env.backup" ]; then
        mv "$PROJECT_ROOT/langgraph_app/.env.backup" "$PROJECT_ROOT/langgraph_app/.env"
        log_info "Restored langgraph_app/.env"
    fi

    rm -f /tmp/tunnel_output.log

    log_info "Cleanup complete"
}

trap cleanup EXIT

KILL_EXISTING=false

show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Start all Launch10 services with Cloudflare tunnels for remote sharing."
    echo ""
    echo "Options:"
    echo "  --kill, -k    Kill any existing processes on required ports"
    echo "  --help, -h    Show this help"
    echo ""
    echo "Requires:"
    echo "  brew install cloudflared"
    echo "  gem install foreman (or brew install overmind)"
}

check_dependencies() {
    log_info "Checking dependencies..."

    local missing=()

    if ! command -v cloudflared &> /dev/null; then
        missing+=("cloudflared (brew install cloudflared)")
    fi

    # Check for process manager
    if ! command -v overmind &> /dev/null && ! command -v foreman &> /dev/null; then
        missing+=("foreman (gem install foreman) or overmind (brew install overmind)")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies:"
        for dep in "${missing[@]}"; do
            echo "  - $dep"
        done
        exit 1
    fi

    log_success "Dependencies OK"
}

check_infrastructure() {
    log_info "Checking infrastructure..."

    if ! pg_isready -q 2>/dev/null; then
        log_error "PostgreSQL not running. Start with: brew services start postgresql"
        exit 1
    fi
    log_success "PostgreSQL running"

    if ! lsof -i :6379 > /dev/null 2>&1; then
        log_error "Redis not running. Start with: brew services start redis"
        exit 1
    fi
    log_success "Redis running"
}

kill_port() {
    local port=$1
    local pid=$(lsof -ti :$port 2>/dev/null)
    if [ -n "$pid" ]; then
        log_info "Killing process $pid on port $port"
        kill $pid 2>/dev/null || true
    fi
}

check_ports() {
    log_info "Checking ports..."

    local ports_in_use=()
    for port in 3000 5173 8080; do
        if lsof -i :$port > /dev/null 2>&1; then
            ports_in_use+=($port)
        fi
    done

    if [ ${#ports_in_use[@]} -gt 0 ]; then
        if [ "$KILL_EXISTING" = true ]; then
            log_info "Killing existing processes on ports: ${ports_in_use[*]}"
            for port in "${ports_in_use[@]}"; do
                kill_port $port
            done
            sleep 2
            log_success "Ports cleared"
        else
            log_warn "Ports already in use: ${ports_in_use[*]}"
            echo ""
            echo "Options:"
            echo "  1. Run with --kill to auto-kill existing processes"
            echo "  2. Kill manually: kill \$(lsof -ti :3000,:5173,:8080)"
            echo ""
            read -p "Kill them now? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                for port in "${ports_in_use[@]}"; do
                    kill_port $port
                done
                sleep 2
                log_success "Ports cleared"
            else
                exit 1
            fi
        fi
    else
        log_success "Ports available"
    fi
}

backup_env_files() {
    cp "$PROJECT_ROOT/rails_app/.env" "$PROJECT_ROOT/rails_app/.env.backup"
    cp "$PROJECT_ROOT/langgraph_app/.env" "$PROJECT_ROOT/langgraph_app/.env.backup"
    log_info "Backed up .env files"
}

# Monitor tunnel output and extract URLs
monitor_tunnels() {
    local rails_url=""
    local api_url=""

    log_info "Waiting for tunnel URLs..."

    # Give services time to start
    sleep 8

    # Watch the log for URLs (timeout after 60 seconds)
    local attempts=0
    while [ $attempts -lt 60 ]; do
        if [ -z "$rails_url" ]; then
            rails_url=$(grep -o 'https://[^[:space:]]*\.trycloudflare\.com' /tmp/tunnel_output.log 2>/dev/null | head -1)
        fi
        if [ -z "$api_url" ]; then
            api_url=$(grep -o 'https://[^[:space:]]*\.trycloudflare\.com' /tmp/tunnel_output.log 2>/dev/null | tail -1)
        fi

        if [ -n "$rails_url" ] && [ -n "$api_url" ] && [ "$rails_url" != "$api_url" ]; then
            break
        fi

        sleep 1
        attempts=$((attempts + 1))
    done

    if [ -z "$rails_url" ] || [ -z "$api_url" ]; then
        log_warn "Could not detect tunnel URLs automatically"
        log_warn "Check the output above for .trycloudflare.com URLs"
        return
    fi

    # Update .env files
    sed -i '' '/^VITE_LANGGRAPH_API_URL=/d' "$PROJECT_ROOT/rails_app/.env"
    sed -i '' '/^LANGGRAPH_API_URL=/d' "$PROJECT_ROOT/rails_app/.env"
    echo "VITE_LANGGRAPH_API_URL=$api_url" >> "$PROJECT_ROOT/rails_app/.env"
    echo "LANGGRAPH_API_URL=$api_url" >> "$PROJECT_ROOT/rails_app/.env"

    sed -i '' '/^RAILS_API_URL=/d' "$PROJECT_ROOT/langgraph_app/.env"
    sed -i '' '/^ALLOWED_ORIGINS=/d' "$PROJECT_ROOT/langgraph_app/.env"
    echo "RAILS_API_URL=$rails_url" >> "$PROJECT_ROOT/langgraph_app/.env"
    echo "ALLOWED_ORIGINS=$rails_url" >> "$PROJECT_ROOT/langgraph_app/.env"

    echo ""
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  TUNNEL URLS READY${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${BLUE}Share with cofounder:${NC}  ${YELLOW}$rails_url${NC}"
    echo -e "  ${BLUE}API URL:${NC}              $api_url"
    echo ""
    echo -e "  ${YELLOW}NOTE: Restart services (Ctrl+C, then run again) to use new URLs${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo ""
}

main() {
    # Parse args
    while [[ $# -gt 0 ]]; do
        case $1 in
            --kill|-k)
                KILL_EXISTING=true
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done

    echo ""
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    echo -e "${BLUE}  Launch10 Tunnel${NC}"
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    echo ""

    check_dependencies
    check_infrastructure
    check_ports
    backup_env_files

    cd "$PROJECT_ROOT"

    # Start URL monitoring in background
    > /tmp/tunnel_output.log
    (sleep 5 && monitor_tunnels) &

    log_info "Starting services with tunnels..."
    echo ""

    # Use overmind if available, otherwise foreman
    if command -v overmind &> /dev/null; then
        overmind start -f Procfile.tunnel 2>&1 | tee -a /tmp/tunnel_output.log
    else
        foreman start -f Procfile.tunnel 2>&1 | tee -a /tmp/tunnel_output.log
    fi
}

main "$@"
