#!/usr/bin/env bash

# Launch10 Tunnel Script
# Uses Overmind to manage all services + Cloudflare tunnels for remote sharing.
# Built on the unified service infrastructure (config/services.sh).

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Use development environment for tunnels (external access to dev setup)
export LAUNCH10_ENV=development
source "$PROJECT_ROOT/config/services.sh"

# Colors for output (shared with bin/services)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[tunnel]${NC} $1"; }
log_success() { echo -e "${GREEN}[tunnel]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[tunnel]${NC} $1"; }
log_error() { echo -e "${RED}[tunnel]${NC} $1"; }

cleanup() {
    log_info "Cleaning up..."

    # Restore .env files
    if [ -f "$RAILS_APP_DIR/.env.backup" ]; then
        mv "$RAILS_APP_DIR/.env.backup" "$RAILS_APP_DIR/.env"
        log_info "Restored rails_app/.env"
    fi
    if [ -f "$LANGGRAPH_APP_DIR/.env.backup" ]; then
        mv "$LANGGRAPH_APP_DIR/.env.backup" "$LANGGRAPH_APP_DIR/.env"
        log_info "Restored langgraph_app/.env"
    fi

    rm -f /tmp/tunnel_output.log
    rm -f /tmp/tunnel_urls_ready

    log_info "Cleanup complete"
}

trap cleanup EXIT

KILL_EXISTING=false

show_help() {
    echo "Usage: $0 [OPTIONS]"
    echo ""
    echo "Start all Launch10 services with Cloudflare tunnels for remote sharing."
    echo ""
    echo "Options:"
    echo "  --kill, -k    Kill any existing processes on required ports"
    echo "  --help, -h    Show this help"
    echo ""
    echo "Ports (from config/services.sh):"
    echo "  Rails:     $RAILS_PORT"
    echo "  Langgraph: $LANGGRAPH_PORT"
    echo "  Vite:      $VITE_PORT"
    echo ""
    echo "Requires:"
    echo "  brew install cloudflared overmind"
}

check_dependencies() {
    log_info "Checking dependencies..."

    local missing=()

    if ! command -v cloudflared &> /dev/null; then
        missing+=("cloudflared (brew install cloudflared)")
    fi

    if ! command -v overmind &> /dev/null; then
        missing+=("overmind (brew install overmind)")
    fi

    if [ ${#missing[@]} -gt 0 ]; then
        log_error "Missing dependencies:"
        for dep in "${missing[@]}"; do
            echo "  - $dep"
        done
        exit 1
    fi

    log_success "Dependencies OK"
}

check_infrastructure() {
    log_info "Checking infrastructure..."

    if ! pg_isready -q 2>/dev/null; then
        log_error "PostgreSQL not running. Start with: brew services start postgresql"
        exit 1
    fi
    log_success "PostgreSQL running"

    if ! lsof -i :6379 > /dev/null 2>&1; then
        log_error "Redis not running. Start with: brew services start redis"
        exit 1
    fi
    log_success "Redis running"
}

is_port_in_use() {
    lsof -ti :$1 >/dev/null 2>&1
}

kill_port() {
    local port=$1
    local pid=$(lsof -ti :$port 2>/dev/null)
    if [ -n "$pid" ]; then
        log_info "Killing process $pid on port $port"
        kill $pid 2>/dev/null || true
    fi
}

check_ports() {
    log_info "Checking ports..."

    local ports_in_use=()
    for port in $RAILS_PORT $LANGGRAPH_PORT $VITE_PORT; do
        if is_port_in_use $port; then
            ports_in_use+=($port)
        fi
    done

    if [ ${#ports_in_use[@]} -gt 0 ]; then
        if [ "$KILL_EXISTING" = true ]; then
            log_info "Killing existing processes on ports: ${ports_in_use[*]}"
            for port in "${ports_in_use[@]}"; do
                kill_port $port
            done
            sleep 2
            log_success "Ports cleared"
        else
            log_warn "Ports already in use: ${ports_in_use[*]}"
            echo ""
            echo "Options:"
            echo "  1. Run with --kill to auto-kill existing processes"
            echo "  2. Kill manually: kill \$(lsof -ti :${RAILS_PORT},:${LANGGRAPH_PORT},:${VITE_PORT})"
            echo ""
            read -p "Kill them now? [y/N] " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                for port in "${ports_in_use[@]}"; do
                    kill_port $port
                done
                sleep 2
                log_success "Ports cleared"
            else
                exit 1
            fi
        fi
    else
        log_success "Ports available"
    fi
}

backup_env_files() {
    cp "$RAILS_APP_DIR/.env" "$RAILS_APP_DIR/.env.backup"
    cp "$LANGGRAPH_APP_DIR/.env" "$LANGGRAPH_APP_DIR/.env.backup"
    log_info "Backed up .env files"
}

# Monitor tunnel output and extract URLs
monitor_tunnels() {
    local rails_url=""
    local api_url=""

    log_info "Waiting for tunnel URLs..."

    # Watch the log for URLs (timeout after 60 seconds)
    local attempts=0
    while [ $attempts -lt 60 ]; do
        if [ -z "$rails_url" ]; then
            rails_url=$(grep 'tunnel_rails' /tmp/tunnel_output.log 2>/dev/null | grep -o 'https://[^[:space:]|]*\.trycloudflare\.com' | head -1)
        fi
        if [ -z "$api_url" ]; then
            api_url=$(grep 'tunnel_api' /tmp/tunnel_output.log 2>/dev/null | grep -o 'https://[^[:space:]|]*\.trycloudflare\.com' | head -1)
        fi

        if [ -n "$rails_url" ] && [ -n "$api_url" ]; then
            break
        fi

        sleep 1
        attempts=$((attempts + 1))
    done

    if [ -z "$rails_url" ] || [ -z "$api_url" ]; then
        log_warn "Could not detect tunnel URLs automatically"
        log_warn "Check the output above for .trycloudflare.com URLs"
        log_warn "Services are waiting - create /tmp/tunnel_urls_ready manually after updating .env"
        return
    fi

    # Update .env files BEFORE signaling services to start
    # Rails app needs: langgraph URL + its own URL for frontend API calls
    sed -i '' '/^VITE_LANGGRAPH_API_URL=/d' "$RAILS_APP_DIR/.env"
    sed -i '' '/^LANGGRAPH_API_URL=/d' "$RAILS_APP_DIR/.env"
    sed -i '' '/^VITE_RAILS_API_URL=/d' "$RAILS_APP_DIR/.env"
    echo "VITE_LANGGRAPH_API_URL=$api_url" >> "$RAILS_APP_DIR/.env"
    echo "LANGGRAPH_API_URL=$api_url" >> "$RAILS_APP_DIR/.env"
    echo "VITE_RAILS_API_URL=$rails_url" >> "$RAILS_APP_DIR/.env"

    # Langgraph app needs: rails URL for callbacks + CORS origins
    sed -i '' '/^RAILS_API_URL=/d' "$LANGGRAPH_APP_DIR/.env"
    sed -i '' '/^ALLOWED_ORIGINS=/d' "$LANGGRAPH_APP_DIR/.env"
    echo "RAILS_API_URL=$rails_url" >> "$LANGGRAPH_APP_DIR/.env"
    echo "ALLOWED_ORIGINS=$rails_url" >> "$LANGGRAPH_APP_DIR/.env"

    echo ""
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  TUNNEL URLS READY - Starting services...${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${BLUE}Share with cofounder:${NC}  ${YELLOW}$rails_url${NC}"
    echo -e "  ${BLUE}API URL:${NC}              $api_url"
    echo ""
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo ""

    # Signal services to start
    touch /tmp/tunnel_urls_ready
}

main() {
    # Parse args
    while [[ $# -gt 0 ]]; do
        case $1 in
            --kill|-k)
                KILL_EXISTING=true
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done

    echo ""
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    echo -e "${BLUE}  Launch10 Tunnel${NC}"
    echo -e "${BLUE}════════════════════════════════════════${NC}"
    echo ""

    check_dependencies
    check_infrastructure
    check_ports
    backup_env_files

    cd "$PROJECT_ROOT"

    # Clean up any stale signal file
    rm -f /tmp/tunnel_urls_ready
    > /tmp/tunnel_output.log

    # Export ports for Procfile.tunnel
    export RAILS_PORT
    export LANGGRAPH_PORT
    export VITE_PORT
    export RAILS_APP_DIR
    export LANGGRAPH_APP_DIR

    # Start URL monitoring in background
    monitor_tunnels &

    log_info "Starting tunnels first, services will wait for URLs..."
    log_info "Ports: Rails=$RAILS_PORT, Langgraph=$LANGGRAPH_PORT, Vite=$VITE_PORT"
    echo ""

    overmind start -f Procfile.tunnel 2>&1 | tee -a /tmp/tunnel_output.log
}

main "$@"
