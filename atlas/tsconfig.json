{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": ["vite/client", "@cloudflare/workers-types", "@cloudflare/vitest-pool-workers"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "paths": {
      "~/*": [
        "./src/*",
      ],
      "@middleware/*": [
        "./src/middleware/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
    },
  },
}