{
  "name": "landing-page-server",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:wrangler": "wrangler dev",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "cli": "tsx src/cli/index.ts",
    "cli:build": "esbuild src/cli/index.ts --bundle --platform=node --target=node18 --outfile=dist/cli.js --external:miniflare"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "hono": "^4.9.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "@cloudflare/workers-types": "^4.20250813.0",
    "@types/node": "^24.3.0",
    "dotenv": "^17.2.1",
    "esbuild": "^0.24.2",
    "miniflare": "^3.20241205.0",
    "tsx": "^4.19.2",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.30.0"
  }
}