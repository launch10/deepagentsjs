# Launch10 Tunnel - runs all services + cloudflare tunnels
# Usage: overmind start -f Procfile.tunnel (or foreman start -f Procfile.tunnel)
#
# Tunnels start immediately, services wait for tunnel URLs to be detected
# and written to .env files (handled by bin/tunnel script)

tunnel_rails: cloudflared tunnel --url http://localhost:3000
tunnel_api: cloudflared tunnel --url http://localhost:8080
rails: while [ ! -f /tmp/tunnel_urls_ready ]; do sleep 1; done && cd rails_app && PORT=3000 bundle exec rails server -p 3000
vite: while [ ! -f /tmp/tunnel_urls_ready ]; do sleep 1; done && cd rails_app && bin/vite dev
langgraph: while [ ! -f /tmp/tunnel_urls_ready ]; do sleep 1; done && cd langgraph_app && PORT=8080 pnpm run dev
