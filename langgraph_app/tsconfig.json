{
  "compilerOptions": {
    /* Base Options: */
    // enables better interoperability between ES modules and CommonJS modules, specifically with imports
    "esModuleInterop": true,
    // Skips type checking of .d.ts files, which prevents node_modules from causing errors
    "skipLibCheck": true,
    // Use latest stable version
    "target": "ES2022",
    // Required for using our decorators
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    // Use ES module syntax
    "verbatimModuleSyntax": true,
    // Allow JS files to be imported
    "allowJs": true,
    // Allow JSON files to be imported
    "resolveJsonModule": true,
    "moduleDetection": "force",

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    /* We're not transpiliing */
    "moduleResolution": "Bundler",
    "module": "preserve",
    "noEmit": true,

    "lib": ["ES2022", "ESNext.Disposable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@app": ["./app/index.ts"],
      "@annotation": ["./app/annotation/index.ts"],
      "@prompts": ["./app/prompts/index.ts"],
      "@nodes": ["./app/nodes/index.ts"],
      "@middleware": ["./app/core/node/middleware/index.ts"],
      "@graphs": ["./app/graphs/index.ts"],
      "@rails_api": ["../shared/lib/api/index.ts"],
      "@ext": ["./app/ext/index.ts"],
      "@factories": ["./tests/factories/index.ts"],
      "@state": ["../shared/state/index.ts"],
      "@types": ["../shared/types/index.ts"],
      "@shared/*": ["./app/lib/shared/*"],
      "@db": ["app/db/index.ts"],
      "@core": ["./app/core/index.ts"],
      "@services": ["./app/services/index.ts"],
      "@tools": ["app/tools/index.ts"],
      "@tests/*": ["./tests/*"],
      "@registries": ["./app/models/registries/index.ts"],
      "@support": ["./tests/support/index.ts"],
      "@utils": ["./app/utils/index.ts"],
      "@queues": ["./app/queues/index.ts"],
      "@workers": ["./app/workers/index.ts"]
    },
    // vite takes care of building everything, not tsc
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["app/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "tests/TODO"]
}
