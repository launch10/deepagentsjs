ties\\\":{\\\"projectName\\\":{\\\"type\\\":\\\"string\\\",\\\"description\\\":\\\"The unique-name-of-the-project using kebab-case\\\"}},\\\"required\\\":[\\\"projectName\\\"],\\\"additionalProperties\\\":false,\\\"$schema\\\":\\\"http://json-schema.org/draft-07/schema#\\\"}\\n```\\n</structured-output>\\n\"\n    }\n  ]\n}"
