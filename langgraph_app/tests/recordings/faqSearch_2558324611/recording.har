            "text": "{\"id\":\"ff42a42d-65d6-4ce0-87bb-aa290e50d674\",\"results\":[{\"index\":0,\"relevance_score\":0.542161},{\"index\":4,\"relevance_score\":0.46964246},{\"index\":7,\"relevance_score\":0.43122545},{\"index\":3,\"relevance_score\":0.39592856},{\"index\":2,\"relevance_score\":0.3180195}],\"meta\":{\"api_version\":{\"version\":\"2\"},\"billed_units\":{\"search_units\":1}}}"
