          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n    <background>\\n      The user and agent have been brainstorming about their business idea.\\n    </background>\\n\\n    <available_topics>\\n      \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n    </available_topics>\\n\\n    <task>\\n      Read the recent chat history, and summarize their answers,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n\\n      If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </task>\\n    \\n    <chat-history>\\n  <message>... 2 more messages...</message>\\n  <message>assistant: \\\"Great! Your idea is crystal clear and has a real differentiator. Now let's dig into your audience.\\\\n\\\\n```json\\\\n{\\\\n  \\\\\\\"type\\\\\\\": \\\\\\\"reply\\\\\\\",\\\\n  \\\\\\\"text\\\\\\\": \\\\\\\"Let's talk about your target audience. Who are you primarily going after first—podcast hosts or podcast guests? And what's their biggest pain point or goal that Friend of the Pod solves?\\\\\\\",\\\\n  \\\\\\\"examples\\\\\\\": [\\\\n    \\\\\\\"Indie podcast hosts who struggle to find quality guests and spend hours on outreach\\\\\\\",\\\\n    \\\\\\\"Established hosts looking to scale their guest booking process\\\\\\\",\\\\n    \\\\\\\"Aspiring guests trying to get podcast appearances for visibility\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"conclusion\\\\\\\": \\\\\\\"Tell me who you're targeting and what problem keeps them up at night.\\\\\\\"\\\\n}\\\\n```\\\"</message>\\n  <message>human: \\\"\\\\n        My target audience is podcast hosts with large audiences.\\\\n        They want to find guests that are a good fit for their show,\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\n        who don't add value to their shows.\\\\n    \\\"</message>\\n</chat-history>\\n\\n    <output>\\n      Return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </output>\\n  \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 750,
          "content": {
            "mimeType": "application/json",
            "size": 750,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01Wx7v2qk8QWsgNqMoZpTXoF\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_017eAfYdtmUKUJHRxkeG9mt5\",\"name\":\"extract\",\"input\":{\"output\":[{\"topic\":\"audience\",\"summary\":\"Target audience is podcast hosts with large audiences. Their main pain point is being bombarded with messages from low-quality, spammy guests who don't add value to their shows. They want to find guests that are a good fit for their show.\"}]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1322,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":106,\"service_tier\":\"standard\"}}"
