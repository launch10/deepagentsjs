          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n    <background>\\n      The user and agent have been brainstorming about their business idea.\\n    </background>\\n\\n    <available_topics>\\n      \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n    </available_topics>\\n\\n    <task>\\n      Read the recent chat history, and summarize their answers,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n\\n      If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </task>\\n    \\n    <chat-history>\\n  <message>... 2 more messages...</message>\\n  <message>assistant: \\\"That's awesome! And what about your solution?\\\"</message>\\n  <message>human: \\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\n                are predicted to not be a good fit for your show.\\\\n            \\\"</message>\\n</chat-history>\\n\\n    <output>\\n      Return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </output>\\n  \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 1045,
          "content": {
            "mimeType": "application/json",
            "size": 1045,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_019gGpAxtSEZybMV7NLdgBD3\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_014zEA2DAnw2beqAXjWona2Z\",\"name\":\"extract\",\"input\":{\"output\":[{\"topic\":\"solution\",\"summary\":\"Friend of the Pod solves the guest-matching problem for podcast hosts through AI-powered matching. The platform offers 100+ filters to find the perfect guest for a show, using AI to match hosts and guests based on their content, audience, and goals. What differentiates them is their proprietary AI models trained on messages that successful podcast hosts receive, which they use to filter out pitches predicted to not be a good fit for the show. This saves hosts time by eliminating poor-fit guest pitches before they even see them.\"}]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1200,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":166,\"service_tier\":\"standard\"}}"
