            "text": "{\"model\":\"claude-sonnet-4-5-20250929\",\"id\":\"msg_01L5jWYr744Q7fXQFMzV287i\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"```json\\n{\\n  \\\"type\\\": \\\"reply\\\",\\n  \\\"text\\\": \\\"Absolutely not! Your data is completely private and secure. We don't steal, sell, or share your business ideas with anyone. Everything you've shared stays confidential and is only used to help build YOUR landing page. Your intellectual property is yours alone. We're just here to help you bring your vision to life!\\\"\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":4068,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":90,\"service_tier\":\"standard\"}}"
