          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n      The user and agent have been brainstorming about their business idea.\\n\\n      Specifically, they're working on idea.\\n\\n      Previously, they've provided the following information:\\n\\n      undefined\\n\\n      Read the recent chat history, and summarize their answer to idea,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n      \\n      <chat-history>\\n  <message>assistant: \\\"What is your business?\\\"</message>\\n  <message>human: \\\"I have an idea for a business\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"Basically, it will be for fitness\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"I am a fitness trainer\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"I'm a trainer for men in their 50s, nobody caters to them\\\"</message>\\n</chat-history>\\n    \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 1009,
          "content": {
            "mimeType": "application/json",
            "size": 1009,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01Gg2rKSs9T1LjrUyEsUr42U\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"# Business Idea Summary\\n\\n**Business Type:** Fitness Training\\n\\n**Target Market:** Men in their 50s\\n\\n**Unique Value Proposition:** Specialized fitness training catering to an underserved demographic. The founder has identified a gap in the market—there are currently no fitness services specifically designed for men in their 50s.\\n\\n**Founder Background:** Experienced fitness trainer with expertise in this niche market\\n\\n**Key Insight:** The business addresses an unmet need, positioning itself as the dedicated solution for mature male fitness enthusiasts who lack tailored training options.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":302,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":124,\"service_tier\":\"standard\"}}"
