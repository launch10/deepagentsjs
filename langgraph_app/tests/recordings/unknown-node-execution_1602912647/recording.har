          "method": "POST",
          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n      <background>\\n        The user and agent have been brainstorming about their business idea.\\n      </background>\\n\\n      <available_topics>\\n        \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n      </available_topics>\\n\\n      <task>\\n        Read the recent chat history, and summarize their answers,\\n        preserving as much information as possible. This will be used to generate \\n        persuasive marketing copy, so be sure to capture all the details.\\n\\n        If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n        {\\n            topic: string,\\n            summary: string,\\n        }\\n      </task>\\n      \\n      <chat-history>\\n  <message>... 6 more messages...</message>\\n  <message>assistant: \\\"What is your business?\\\"</message>,\\n  <message>assistant: \\\"Friend of the Pod is a podcast matchmaking service.\\\\n            We help both sides: hosts get great content, guests get exposure,\\\\n            and we're the only platform that does this at scale.\\\\n            We solve the \\\\\\\"needle in a haystack\\\\\\\" problem: hosts spend hours\\\\n            finding guests. We do it in minutes with AI-powered filtering.\\\"</message>,\\n  <message>assistant: \\\"That's awesome! And what about your audience?\\\"</message>,\\n  <message>assistant: \\\"\\\\n        My target audience is podcast hosts with large audiences.\\\\n        They want to find guests that are a good fit for their show,\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\n        who don't add value to their shows.\\\\n    \\\"</message>,\\n  <message>assistant: \\\"That's awesome! And what about your solution?\\\"</message>,\\n  <message>human: \\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\n                are predicted to not be a good fit for your show.\\\\n            \\\"</message>\\n  <message>assistant: \\\"What is your business?\\\"</message>\\n  <message>assistant: \\\"Friend of the Pod is a podcast matchmaking service.\\\\n            We help both sides: hosts get great content, guests get exposure,\\\\n            and we're the only platform that does this at scale.\\\\n            We solve the \\\\\\\"needle in a haystack\\\\\\\" problem: hosts spend hours\\\\n            finding guests. We do it in minutes with AI-powered filtering.\\\"</message>\\n  <message>assistant: \\\"That's awesome! And what about your audience?\\\"</message>\\n  <message>assistant: \\\"\\\\n        My target audience is podcast hosts with large audiences.\\\\n        They want to find guests that are a good fit for their show,\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\n        who don't add value to their shows.\\\\n    \\\"</message>\\n  <message>assistant: \\\"That's awesome! And what about your solution?\\\"</message>\\n  <message>human: \\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\n                are predicted to not be a good fit for your show.\\\\n            \\\"</message>\\n</chat-history>\\n\\n      <output>\\n        Return an array of objects with the following shape:\\n        {\\n            topic: string,\\n            summary: string,\\n        }\\n      </output>\\n    \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 1617,
          "content": {
            "mimeType": "application/json",
            "size": 1617,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_019Ca6rrizYM2WjMWx73fgt1\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01XVUYkZJQ5PoGupKyA2VGnq\",\"name\":\"extract\",\"input\":{\"output\":[{\"topic\":\"idea\",\"summary\":\"Friend of the Pod is a podcast matchmaking service that helps both podcast hosts and guests. Hosts get great content, guests get exposure. The platform solves the \\\"needle in a haystack\\\" problem where hosts spend hours finding guests - Friend of the Pod does it in minutes using AI-powered filtering. They are the only platform that does this at scale.\"},{\"topic\":\"audience\",\"summary\":\"Target audience is podcast hosts with large audiences. These hosts want to find guests that are a good fit for their show, but they face a major pain point: they're bombarded with messages from low-quality, spammy guests who don't add value to their shows.\"},{\"topic\":\"solution\",\"summary\":\"Friend of the Pod offers over 100+ filters to find the perfect guest for a show. The platform uses AI to match hosts and guests based on their content, audience, and goals. What sets them apart is their proprietary AI models trained on messages that successful podcast hosts receive. They use this data to filter out pitches predicted to not be a good fit for the host's show, ensuring only high-quality guest matches are presented.\"}]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1737,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":313,\"service_tier\":\"standard\"}}"
