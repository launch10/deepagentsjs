          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n    <background>\\n      The user and agent have been brainstorming about their business idea.\\n    </background>\\n\\n    <available_topics>\\n      \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n    </available_topics>\\n\\n    <task>\\n      Read the recent chat history, and summarize their answers,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n\\n      If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </task>\\n    \\n    <chat-history>\\n  <message>... 2 more messages...</message>\\n  <message>assistant: \\\"What is your business?\\\"</message>\\n  <message>human: \\\"Friend of the Pod is a podcast matchmaking service.\\\\n            We help both sides: hosts get great content, guests get exposure,\\\\n            and we're the only platform that does this at scale.\\\\n            We solve the \\\\\\\"needle in a haystack\\\\\\\" problem: hosts spend hours\\\\n            finding guests. We do it in minutes with AI-powered filtering.\\\"</message>\\n</chat-history>\\n\\n    <output>\\n      Return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </output>\\n  \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 962,
          "content": {
            "mimeType": "application/json",
            "size": 962,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_017x6a5kz3cT1GCQ2MLY5RJa\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01NthFF6RMER8F3HL42siff4\",\"name\":\"extract\",\"input\":{\"output\":[{\"topic\":\"idea\",\"summary\":\"Friend of the Pod is a podcast matchmaking service that connects podcast hosts with guests at scale. The platform solves the \\\"needle in a haystack\\\" problem by using AI-powered filtering to match hosts with ideal guests in minutes, rather than hosts spending hours searching manually. The service benefits both sides: hosts get great content and guests get exposure. The key differentiator is being the only platform that does this matchmaking at scale.\"}]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1158,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":143,\"service_tier\":\"standard\"}}"
