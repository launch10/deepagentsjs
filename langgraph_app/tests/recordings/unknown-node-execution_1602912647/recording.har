          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n      <background>\\n        The user and agent have been brainstorming about their business idea.\\n      </background>\\n\\n      <topic>\\n        audience\\n      </topic>\\n\\n      <task>\\n        Read the recent chat history, and summarize their answer to: audience,\\n        preserving as much information as possible. This will be used to generate \\n        persuasive marketing copy, so be sure to capture all the details.\\n      </task>\\n      \\n      <chat-history>\\n  <message>assistant: \\\"What is your business?\\\"</message>\\n  <message>human: \\\"I have an idea for a business\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"Basically, it will be for fitness\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"I am a fitness trainer\\\"</message>\\n  <message>assistant: \\\"Interesting, I need some more information! Can you tell me more about that?\\\"</message>\\n  <message>human: \\\"I'm a trainer for men in their 50s, nobody caters to them\\\"</message>\\n</chat-history>\\n    \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 1104,
          "content": {
            "mimeType": "application/json",
            "size": 1104,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01BJC125bfXqev2Gu5cq3ajC\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"# Audience Summary\\n\\n**Primary Audience:** Men in their 50s\\n\\n**Key Insight:** This is an underserved market segment. The user has identified a gap in the fitness industry—there is currently a lack of fitness training services specifically tailored to men in this age group.\\n\\n**User's Positioning:** The user is a fitness trainer with direct expertise and experience working with this demographic, positioning them well to address this unmet need.\\n\\n**Marketing Angle:** This audience represents an opportunity to fill a void in the market by offering specialized, age-appropriate fitness training designed specifically for the needs, goals, and physical considerations of men in their 50s.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":311,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":143,\"service_tier\":\"standard\"}}"
