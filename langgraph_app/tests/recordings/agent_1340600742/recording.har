 \\\\\\\"messages\\\\\\\",\\\\n        \\\\\\\"HumanMessage\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"kwargs\\\\\\\": {\\\\n        \\\\\\\"lc_serializable\\\\\\\": true,\\\\n        \\\\\\\"lc_kwargs\\\\\\\": {\\\\n          \\\\\\\"lc_serializable\\\\\\\": true,\\\\n          \\\\\\\"lc_kwargs\\\\\\\": {\\\\n            \\\\\\\"content\\\\\\\": \\\\\\\"\\\\\\\\n        My target audience is podcast hosts with large audiences.\\\\\\\\n        They want to find guests that are a good fit for their show,\\\\\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\\\\\n        who don't add value to their shows.\\\\\\\\n    \\\\\\\",\\\\n            \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n            \\\\\\\"response_metadata\\\\\\\": {}\\\\n          },\\\\n          \\\\\\\"lc_namespace\\\\\\\": [\\\\n            \\\\\\\"langchain_core\\\\\\\",\\\\n            \\\\\\\"messages\\\\\\\"\\\\n          ],\\\\n          \\\\\\\"id\\\\\\\": \\\\\\\"c2e54ace-5771-482b-8463-86355776f657\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"\\\\\\\\n        My target audience is podcast hosts with large audiences.\\\\\\\\n        They want to find guests that are a good fit for their show,\\\\\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\\\\\n        who don't add value to their shows.\\\\\\\\n    \\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"audience\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {}\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"c2e54ace-5771-482b-8463-86355776f657\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"\\\\\\\\n        My target audience is podcast hosts with large audiences.\\\\\\\\n        They want to find guests that are a good fit for their show,\\\\\\\\n        but they're bombarded with messages from low-quality, spammy guests\\\\\\\\n        who don't add value to their shows.\\\\\\\\n    \\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {\\\\n          \\\\\\\"topics\\\\\\\": [\\\\n            \\\\\\\"audience\\\\\\\"\\\\n          ]\\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {}\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc\\\\\\\": 1,\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"constructor\\\\\\\",\\\\n      \\\\\\\"id\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\",\\\\n        \\\\\\\"AIMessage\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"kwargs\\\\\\\": {\\\\n        \\\\\\\"lc_serializable\\\\\\\": true,\\\\n        \\\\\\\"lc_kwargs\\\\\\\": {\\\\n          \\\\\\\"lc_serializable\\\\\\\": true,\\\\n          \\\\\\\"lc_kwargs\\\\\\\": {\\\\n            \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your solution?\\\\\\\",\\\\n            \\\\\\\"tool_calls\\\\\\\": [],\\\\n            \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n            \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n            \\\\\\\"response_metadata\\\\\\\": {}\\\\n          },\\\\n          \\\\\\\"lc_namespace\\\\\\\": [\\\\n            \\\\\\\"langchain_core\\\\\\\",\\\\n            \\\\\\\"messages\\\\\\\"\\\\n          ],\\\\n          \\\\\\\"id\\\\\\\": \\\\\\\"2755ed80-08fa-4fe7-9e05-7abd64dbe180\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your solution?\\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"idea\\\\\\\",\\\\n              \\\\\\\"solution\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {},\\\\n          \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n          \\\\\\\"tool_calls\\\\\\\": []\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"2755ed80-08fa-4fe7-9e05-7abd64dbe180\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your solution?\\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {\\\\n          \\\\\\\"topics\\\\\\\": [\\\\n            \\\\\\\"idea\\\\\\\",\\\\n            \\\\\\\"solution\\\\\\\"\\\\n          ]\\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"tool_calls\\\\\\\": []\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc\\\\\\\": 1,\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"constructor\\\\\\\",\\\\n      \\\\\\\"id\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\",\\\\n        \\\\\\\"HumanMessage\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"kwargs\\\\\\\": {\\\\n        \\\\\\\"lc_serializable\\\\\\\": true,\\\\n        \\\\\\\"lc_kwargs\\\\\\\": {\\\\n          \\\\\\\"lc_serializable\\\\\\\": true,\\\\n          \\\\\\\"lc_kwargs\\\\\\\": {\\\\n            \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n            \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n            \\\\\\\"response_metadata\\\\\\\": {}\\\\n          },\\\\n          \\\\\\\"lc_namespace\\\\\\\": [\\\\n            \\\\\\\"langchain_core\\\\\\\",\\\\n            \\\\\\\"messages\\\\\\\"\\\\n          ],\\\\n          \\\\\\\"id\\\\\\\": \\\\\\\"7b862522-b220-4d00-86d0-f21bf98c123b\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"idea\\\\\\\",\\\\n              \\\\\\\"solution\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {}\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"7b862522-b220-4d00-86d0-f21bf98c123b\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {\\\\n          \\\\\\\"topics\\\\\\\": [\\\\n            \\\\\\\"idea\\\\\\\",\\\\n            \\\\\\\"solution\\\\\\\"\\\\n          ]\\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {}\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n        \\\\\\\"tool_calls\\\\\\\": [],\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"94f10437-76f6-4cad-bb22-c15d6afe4d92\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"94f10437-76f6-4cad-bb22-c15d6afe4d92\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"ai\\\\\\\",\\\\n      \\\\\\\"tool_calls\\\\\\\": [],\\\\n      \\\\\\\"invalid_tool_calls\\\\\\\": []\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"34533b20-6bee-4737-96ac-01fbfbd9345a\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"34533b20-6bee-4737-96ac-01fbfbd9345a\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"human\\\\\\\"\\\\n    }\\\\n  ]\\\\n}\\\"</message>\\n</chat-history>\\n        \\n        <task>\\n            Explain the user's options to them, or answer any questions they may have\\n            about the process.\\n\\n            1. Brand Personalization (optional)\\n            2. Build My Site button\\n        \\n            Make it clear both paths are valid.\\n        \\n            Output JSON: {\\n                \\\"text\\\": \\\"Guide the user to the next step\\\",\\n                \\\"examples\\\": [\\\"Option 1 explanation\\\", \\\"Option 2 explanation\\\"], // Optional, only if necessary\\n                \\\"conclusion\\\": \\\"Clearly state the next step\\\" // Optional, only if necessary\\n            }\\n        </task>\\n    \"}"
