\\": \\\\\\\"572427a4-437d-4227-a0af-f49d61a4f003\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your solution?\\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"solution\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {},\\\\n          \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n          \\\\\\\"tool_calls\\\\\\\": []\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"572427a4-437d-4227-a0af-f49d61a4f003\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your solution?\\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {\\\\n          \\\\\\\"topics\\\\\\\": [\\\\n            \\\\\\\"solution\\\\\\\"\\\\n          ]\\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"tool_calls\\\\\\\": []\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc\\\\\\\": 1,\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"constructor\\\\\\\",\\\\n      \\\\\\\"id\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\",\\\\n        \\\\\\\"HumanMessage\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"kwargs\\\\\\\": {\\\\n        \\\\\\\"lc_serializable\\\\\\\": true,\\\\n        \\\\\\\"lc_kwargs\\\\\\\": {\\\\n          \\\\\\\"lc_serializable\\\\\\\": true,\\\\n          \\\\\\\"lc_kwargs\\\\\\\": {\\\\n            \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n            \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n            \\\\\\\"response_metadata\\\\\\\": {}\\\\n          },\\\\n          \\\\\\\"lc_namespace\\\\\\\": [\\\\n            \\\\\\\"langchain_core\\\\\\\",\\\\n            \\\\\\\"messages\\\\\\\"\\\\n          ],\\\\n          \\\\\\\"id\\\\\\\": \\\\\\\"fca1e2f3-fa46-4ed9-b49e-982edecd3150\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"solution\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {}\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"fca1e2f3-fa46-4ed9-b49e-982edecd3150\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {\\\\n          \\\\\\\"topics\\\\\\\": [\\\\n            \\\\\\\"solution\\\\\\\"\\\\n          ]\\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {}\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n        \\\\\\\"tool_calls\\\\\\\": [],\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"baf5d8bd-e3c5-4919-8fde-23ceac6a4438\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"baf5d8bd-e3c5-4919-8fde-23ceac6a4438\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"ai\\\\\\\",\\\\n      \\\\\\\"tool_calls\\\\\\\": [],\\\\n      \\\\\\\"invalid_tool_calls\\\\\\\": []\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"8bc39b38-7a43-47ac-a633-03642fe2e114\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"8bc39b38-7a43-47ac-a633-03642fe2e114\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"human\\\\\\\"\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": [\\\\n          {\\\\n            \\\\\\\"type\\\\\\\": \\\\\\\"tool_use\\\\\\\",\\\\n            \\\\\\\"id\\\\\\\": \\\\\\\"toolu_01DPvaNrTMDqtdVNUWjsEMpV\\\\\\\",\\\\n            \\\\\\\"name\\\\\\\": \\\\\\\"save_answers\\\\\\\",\\\\n            \\\\\\\"input\\\\\\\": {\\\\n              \\\\\\\"save\\\\\\\": true\\\\n            }\\\\n          }\\\\n     