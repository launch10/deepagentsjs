            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01XDzCf3Nj5PFkRja9Az6vNP\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"\\n\\nNow, let's spell out some unique features of your business.\\n\\nThis helps your ad take up more real estate, and gives your users more reasons to click. I filled in a few ideas to help get us started.\\n\\n```json\\n{\\n  \\\"callouts\\\": [\\n    \\\"Works Across All Time Zones\\\",\\n    \\\"Syncs With Any Calendar App\\\",\\n    \\\"Finds Times in Seconds\\\",\\n    \\\"No Back-and-Forth Needed\\\",\\n    \\\"Used by 2,000+ Teams\\\",\\n    \\\"Free 14-Day Trial\\\"\\n  ],\\n  \\\"structuredSnippets\\\": {\\n    \\\"category\\\": \\\"Services\\\",\\n    \\\"details\\\": [\\n      \\\"Automatic Availability Matching\\\",\\n      \\\"Calendar Integration\\\",\\n      \\\"Team Preference Settings\\\"\\n    ]\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":3284,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":189,\"service_tier\":\"standard\"}}"
