            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_015mC9YMvU2dzhZR6AVDA49m\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Let me search for best practices on Google Ads headlines and descriptions to ensure these assets are optimized.\"},{\"type\":\"tool_use\",\"id\":\"toolu_01NHDRvK3BqxdqQnS8nspNUo\",\"name\":\"ads_faq\",\"input\":{\"query\":\"Google Ads headlines best practices character limit\",\"tags\":[\"ads\",\"headlines\"]}},{\"type\":\"tool_use\",\"id\":\"toolu_01DMoUrC3JuwhffvNLtt5uhw\",\"name\":\"ads_faq\",\"input\":{\"query\":\"Google Ads descriptions character limit best practices\",\"tags\":[\"ads\",\"descriptions\"]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1830,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":171,\"service_tier\":\"standard\"}}"
