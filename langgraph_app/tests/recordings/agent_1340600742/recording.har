          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"save_answers\",\"description\":\"\\n        Save answers to the brainstorming session. \\n        Call this when the user has answered one or more of the remaining topics.\\n        IMPORTANT: You do not need to call this with any arguments,\\n        it will automatically save the answers from the current thread.\\n    \",\"input_schema\":{\"type\":\"object\",\"properties\":{\"save\":{\"type\":\"boolean\",\"const\":true}},\"required\":[\"save\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}},{\"name\":\"extract-2\",\"description\":\"Tool for extracting structured output from the model's response.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"text\":{\"type\":\"string\",\"description\":\"A simple message or question\"},\"examples\":{\"type\":\"array\",\"items\":{\"type\":\"string\"},\"description\":\"OPTIONAL: List of examples to help the user understand\"},\"conclusion\":{\"type\":\"string\",\"description\":\"OPTIONAL: Conclusion text to include after examples\"}},\"required\":[\"text\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"any\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"assistant\",\"content\":\"What is your business?\"},{\"role\":\"user\",\"content\":\"Friend of the Pod is a podcast matchmaking service.\\n            We help both sides: hosts get great content, guests get exposure,\\n            and we're the only platform that does this at scale.\\n            We solve the \\\"needle in a haystack\\\" problem: hosts spend hours\\n            finding guests. We do it in minutes with AI-powered filtering.\"},{\"role\":\"assistant\",\"content\":\"That's awesome! And what about your audience?\"},{\"role\":\"user\",\"content\":\"\\n        My target audience is podcast hosts with large audiences.\\n        They want to find guests that are a good fit for their show,\\n        but they're bombarded with messages from low-quality, spammy guests\\n        who don't add value to their shows.\\n    \"},{\"role\":\"assistant\",\"content\":\"That's awesome! And what about your solution?\"},{\"role\":\"user\",\"content\":\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\n                But what sets us apart is that we've trained proprietary models on messages that \\n                successful podcast hosts receive. We use this data to filter out pitches that \\n                are predicted to not be a good fit for your show.\\n            \"},{\"role\":\"assistant\",\"content\":\"That's awesome! And what about your social proof?\"},{\"role\":\"user\",\"content\":\"Over 10k creators use Friend of the Pod to find guests for their shows.\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\"},{\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01NTPdMbW7RxAo1wPAn8JpD6\",\"name\":\"save_answers\",\"input\":{\"save\":true}}]},{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"{\\n  \\\"memories\\\": {\\n    \\\"idea\\\": \\\"Friend of the Pod is a platform that helps podcast hosts find the perfect guests. The business uses AI to match hosts and guests based on their content, audience, and goals. What sets them apart is their proprietary AI models trained on messages that successful podcast hosts receive, which they use to filter out pitches predicted to not be a good fit for a show. The platform offers over 100+ filters to help hosts find ideal guests.\\\",\\n    \\\"audience\\\": \\\"Target audience is podcast hosts with large audiences. Their main pain points are: (1) difficulty finding guests that are a good fit for their show, and (2) being bombarded with messages from low-quality, spammy guests who don't add value to their shows. Their goal is to find high-quality, relevant guests that enhance their podcast content.\\\",\\n    \\\"solution\\\": \\\"Friend of the Pod solves the problem of finding quality podcast guests through AI-powered matching and intelligent filtering. The solution uses AI to analyze content, audience, and goals to match compatible hosts and guests. Their proprietary models trained on successful podcast host messages predict which pitches will be a good fit, filtering out poor matches before they reach the host. This saves hosts time and improves the quality of guest selection with 100+ customizable filters.\\\",\\n    \\\"socialProof\\\": \\\"Over 10k creators actively use Friend of the Pod to find guests for their shows. Real case study: A host found 3 qualified guests in just 10 minutes instead of spending 5 hours on manual outreach, which resulted in 2 viral episodes. Founder has direct industry expertise from previous roles at Spotify and Apple Podcasts, giving deep understanding of what makes a guest a good fit for a show and intimate knowledge of the podcast industry.\\\",\\n    \\\"lookAndFeel\\\": null\\n  },\\n  \\\"messages\\\": [\\n    {\\n      \\\"lc\\\": 1,\\n      \\\"type\\\": \\\"constructor\\\",\\n      \\\"id\\\": [\\n        \\\"langchain_core\\\",\\n        \\\"messages\\\",\\n        \\\"AIMessage\\\"\\n      ],\\n      \\\"kwargs\\\": {\\n        \\\"lc_serializable\\\": true,\\n        \\\"lc_kwargs\\\": {\\n          \\\"lc_serializable\\\": true,\\n          \\\"lc_kwargs\\\": {\\n            \\\"content\\\": \\\"What is your business?\\\",\\n            \\\"tool_calls\\\": [],\\n            \\\"invalid_tool_calls\\\": [],\\n            \\\"additional_kwargs\\\": {},\\n            \\\"response_metadata\\\": {}\\n          },\\n          \\\"lc_namespace\\\": [\\n            \\\"langchain_core\\\",\\n            \\\"messages\\\"\\n          ],\\n          \\\"id\\\": \\\"1144bb52-1fae-4802-9659-e4ac87dde40d\\\",\\n          \\\"content\\\": \\\"What is your business?\\\",\\n          \\\"additional_kwargs\\\": {\\n            \\\"topics\\\": [\\n              \\\"idea\\\"\\n            ]\\n          },\\n          \\\"response_metadata\\\": {},\\n          \\\"invalid_tool_calls\\\": [],\\n          \\\"tool_calls\\\": []\\n        },\\n        \\\"lc_namespace\\\": [\\n          \\\"langchain_core\\\",\\n          \\\"messages\\\"\\n        ],\\n        \\\"id\\\": \\\"1144bb52-1fae-4802-9659-e4ac87dde40d\\\",\\n        \\\"content\\\": \\\"What is your business?\\\",\\n        \\\"additional_kwargs\\\": {\\n          \\\"topics\\\": [\\n            \\\"idea\\\"\\n          ]\\n        },\\n        \\\"response_metadata\\\": {},\\n        \\\"invalid_tool_calls\\\": [],\\n        \\\"tool_calls\\\": []\\n      }\\n    },\\n    {\\n      \\\"lc\\\": 1,\\n      \\\"type\\\": \\\"constructor\\\",\\n      \\\"id\\\": [\\n        \\\"langchain_core\\\",\\n        \\\"messages\\\",\\n        \\\"HumanMessage\\\"\\n      ],\\n      \\\"kwargs\\\": {\\n        \\\"lc_serializable\\\": true,\\n        \\\"lc_kwargs\\\": {\\n          \\\"lc_serializable\\\": true,\\n          \\\"lc_kwargs\\\": {\\n            \\\"content\\\": \\\"Friend of the Pod is a podcast matchmaking service.\\\\n            We help both sides: hosts get great content, guests get exposure,\\\\n            and we're the only platform that does this at scale.\\\\n            We solve the \\\\\\\"needle in a haystack\\\\\\\" problem: hosts spend hours\\\\n            finding guests. We do it in minutes with AI-powered filtering.\\\",\\n    