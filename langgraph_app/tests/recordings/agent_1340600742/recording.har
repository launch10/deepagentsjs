            "mimeType": "application/json",
            "size": 2094,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01FBL1eau9rwhQsu7piuSvDy\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Let's configure your ad settings to optimize performance.\\n\\n```json\\n{\\n  \\\"search_ads\\\": [\\n    {\\n      \\\"headline_1\\\": \\\"Stop the Scheduling Chaos\\\",\\n      \\\"headline_2\\\": \\\"Find Meeting Times in Seconds\\\",\\n      \\\"headline_3\\\": \\\"Works Across All Time Zones\\\",\\n      \\\"description_1\\\": \\\"Connect your calendar. Share preferences. We handle the rest. Distributed teams save 15 hours/week on scheduling.\\\",\\n      \\\"description_2\\\": \\\"Used by 2,000+ remote teams. Cut coordination time by 80%. Your team just clicks yes.\\\"\\n    },\\n    {\\n      \\\"headline_1\\\": \\\"Meeting Scheduling Made Simple\\\",\\n      \\\"headline_2\\\": \\\"Instant Times That Work for Everyone\\\",\\n      \\\"headline_3\\\": \\\"No More Endless Slack Threads\\\",\\n      \\\"description_1\\\": \\\"Eliminate back-and-forth calendar coordination. Suggest optimal meeting times automatically across continents.\\\",\\n      \\\"description_2\\\": \\\"Join TechCorp and thousands of distributed teams. Save hours every week on meeting coordination.\\\"\\n    }\\n  ],\\n  \\\"ad_extensions\\\": {\\n    \\\"callout_extensions\\\": [\\n      \\\"Saves 15 hours per week on scheduling\\\",\\n      \\\"Works across all time zones automatically\\\",\\n      \\\"Used by 2,000+ distributed teams\\\",\\n      \\\"80% reduction in coordination time\\\",\\n      \\\"One-click calendar integration\\\"\\n    ],\\n    \\\"structured_snippet\\\": {\\n      \\\"header\\\": \\\"Key Features\\\",\\n      \\\"values\\\": [\\n        \\\"Automatic time zone detection\\\",\\n        \\\"Calendar sync across platforms\\\",\\n        \\\"Instant availability suggestions\\\",\\n        \\\"Team preference learning\\\"\\n      ]\\n    },\\n    \\\"promotion_extension\\\": \\\"Save 15 hours/week on scheduling. Start free today.\\\"\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":637,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":419,\"service_tier\":\"standard\"}}"
