            "mimeType": "application/json",
            "size": 870,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01LWDCoBbeoboUsqrRBiJ3Ef\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Yes! You can see your headlines in the Ad Preview at the top of the page—it updates in real-time as you edit your headlines and descriptions. Keep in mind that the preview shows just one sample combination of your content, since Google will mix and match your headlines and descriptions in different ways for different users. The preview is great for checking typos, tone, and overall messaging, but it won't show every possible variation your ad could display.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2468,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":95,\"service_tier\":\"standard\"}}"
