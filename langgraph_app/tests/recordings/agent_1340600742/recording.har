      {
        "_id": "2d6c149c9d06e1212a7174d238e33c66",
        "_order": 0,
        "cache": {},
        "request": {
          "bodySize": 11281,
          "cookies": [],
          "headers": [
            {
              "name": "accept",
              "value": "application/json"
            },
            {
              "name": "anthropic-dangerous-direct-browser-access",
              "value": "true"
