            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n    <background>\\n      The user and agent have been brainstorming about their business idea.\\n    </background>\\n\\n    <available_topics>\\n      \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n    </available_topics>\\n\\n    <task>\\n      Read the recent chat history, and summarize their answers,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n\\n      If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </task>\\n    \\n    <chat-history>\\n  <message>... 4 more messages...</message>\\n  <message>assistant: \\\"That's awesome! And what about your solution?\\\"</message>\\n  <message>human: \\\"My fitness program is specifically designed\\\"</message>\\n  <message>assistant: \\\"```json\\\\n{\\\\n  \\\\\\\"type\\\\\\\": \\\\\\\"reply\\\\\\\",\\\\n  \\\\\\\"text\\\\\\\": \\\\\\\"Great start! I can see you're building something really compelling here. You've identified a real pain point - men in their 50s who've been told they're too old AND have no fitness experience. Now I need to understand exactly HOW your program solves this. Can you finish that thought and tell me: what makes your fitness program specifically designed to overcome these barriers? What's different about your approach compared to generic fitness programs?\\\\\\\",\\\\n  \\\\\\\"examples\\\\\\\": [\\\\n    \\\\\\\"My program uses beginner-friendly exercises that don't require prior experience, with modifications for aging joints and recovery needs\\\\\\\",\\\\n    \\\\\\\"I focus on building confidence first through small wins, then gradually increase intensity to prove age is just a number\\\\\\\",\\\\n    \\\\\\\"My program combines personalized coaching with a community of other men in their 50s so they don't feel alone in their journey\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"conclusion\\\\\\\": \\\\\\\"Help me understand the core mechanism of how your program actually solves their problems.\\\\\\\"\\\\n}\\\\n```\\\"</message>\\n  <message>human: \\\"To help men get started lifting, but using bodyweight exercises, and focusing on injury prevention\\\"</message>\\n</chat-history>\\n\\n    <output>\\n      Return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </output>\\n  \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
