ct with this structure:\\n        {\\\"headlines\\\":[\\\"Headline 1\\\",\\\"Headline 2\\\",\\\"Headline 3\\\",\\\"Headline 4\\\",\\\"Headline 5\\\",\\\"Headline 6\\\"],\\\"descriptions\\\":[\\\"Description 1\\\",\\\"Description 2\\\",\\\"Description 3\\\",\\\"Description 4\\\"]}\\n    \"}"
