            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_013NSnQ1sKzLtX8c4aM7xUKx\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01UTTYBfgH6prHsHZEvHkA2L\",\"name\":\"faq\",\"input\":{\"query\":\"How do headlines and descriptions pair together in Google Ads\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2444,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":63,\"service_tier\":\"standard\"}}"
