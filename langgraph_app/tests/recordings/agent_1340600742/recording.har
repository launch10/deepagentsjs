            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_017q6bHRGSynrSa4dP4hjisu\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_012bpdpWCiHmQgohr7hfeSeG\",\"name\":\"faq\",\"input\":{\"query\":\"What are callouts used for in Google Ads\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2316,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":62,\"service_tier\":\"standard\"}}"
