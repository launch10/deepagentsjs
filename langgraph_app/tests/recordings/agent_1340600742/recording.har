          "headersSize": 573,
          "httpVersion": "HTTP/1.1",
          "method": "POST",
          "postData": {
            "mimeType": "application/json",
            "params": [],
            "text": "{\"model\":\"claude-haiku-4-5\",\"temperature\":0,\"top_k\":-1,\"stream\":false,\"max_tokens\":2048,\"tools\":[{\"name\":\"extract\",\"description\":\"A function available to call.\",\"input_schema\":{\"type\":\"object\",\"properties\":{\"output\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"topic\":{\"type\":\"string\"},\"summary\":{\"type\":\"string\"}},\"required\":[\"topic\",\"summary\"],\"additionalProperties\":false}}},\"required\":[\"output\"],\"additionalProperties\":false,\"$schema\":\"http://json-schema.org/draft-07/schema#\"}}],\"tool_choice\":{\"type\":\"tool\",\"name\":\"extract\"},\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"\\n    <background>\\n      The user and agent have been brainstorming about their business idea.\\n    </background>\\n\\n    <available_topics>\\n      \\\"idea: The core business idea. What does the business do? What makes them different?\\\", \\\"audience: The target audience. What are their pain points? What are their goals?\\\", \\\"solution: How does the user's business solve the audience's pain points, or help them reach their goals?\\\", \\\"socialProof: Social proof or testimonials to include on the landing page. Remember, anything can be social proof: the user's background, experience, beliefs, founder story, etc.\\\", \\\"lookAndFeel: The look and feel of the landing page.\\\"\\n    </available_topics>\\n\\n    <task>\\n      Read the recent chat history, and summarize their answers,\\n      preserving as much information as possible. This will be used to generate \\n      persuasive marketing copy, so be sure to capture all the details.\\n\\n      If the user has answered MULTIPLE topics well, return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </task>\\n    \\n    <chat-history>\\n  <message>... 4 more messages...</message>\\n  <message>assistant: \\\"That's awesome! And what about your solution?\\\"</message>\\n  <message>human: \\\"My fitness program is specifically designed\\\"</message>\\n  <message>assistant: \\\"```json\\\\n{\\\\n  \\\\\\\"type\\\\\\\": \\\\\\\"reply\\\\\\\",\\\\n  \\\\\\\"text\\\\\\\": \\\\\\\"Great start! I can see you're building something really powerful here. You've identified a real pain point—men in their 50s who've been told they're too old AND have no fitness experience. Now I need to understand exactly HOW your program solves this. Can you tell me more about what makes your fitness program specifically designed for them? What's different about your approach compared to generic fitness programs?\\\\\\\",\\\\n  \\\\\\\"examples\\\\\\\": [\\\\n    \\\\\\\"My program uses low-impact exercises that are safe for aging joints while still building strength\\\\\\\",\\\\n    \\\\\\\"I start with foundational movements and progress slowly so beginners don't get overwhelmed or injured\\\\\\\",\\\\n    \\\\\\\"My program includes mindset coaching to overcome the psychological barrier that they're 'too old'\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"conclusion\\\\\\\": \\\\\\\"What specific elements of your program address their unique challenges?\\\\\\\"\\\\n}\\\\n```\\\"</message>\\n  <message>human: \\\"To help men get started lifting, but using bodyweight exercises, and focusing on injury prevention\\\"</message>\\n</chat-history>\\n\\n    <output>\\n      Return an array of objects with the following shape:\\n      {\\n          topic: string,\\n          summary: string,\\n      }\\n    </output>\\n  \"}]}"
          },
          "queryString": [],
          "url": "https://api.anthropic.com/v1/messages"
        },
        "response": {
          "bodySize": 783,
          "content": {
            "mimeType": "application/json",
            "size": 783,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01AYXkfg3p15LZaVPFtTwtmh\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01RBkYG9aX6zbftfT4fJoNSU\",\"name\":\"extract\",\"input\":{\"output\":[{\"topic\":\"audience\",\"summary\":\"Men in their 50s who believe they're too old to start fitness and have no fitness experience\"},{\"topic\":\"solution\",\"summary\":\"A fitness program specifically designed to help men get started with lifting using bodyweight exercises, with a strong focus on injury prevention\"}]}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1351,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":121,\"service_tier\":\"standard\"}}"
