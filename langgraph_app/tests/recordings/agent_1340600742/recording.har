            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_011cvBzvE9L4jjKRwGxrCpnX\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Here's a fresh structured snippet highlighting a key capability of your scheduling tool:\\n\\n```json\\n{\\n  \\\"structuredSnippets\\\": {\\n    \\\"category\\\": \\\"Features\\\",\\n    \\\"details\\\": [\\n      \\\"One-Click Scheduling\\\"\\n    ]\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1028,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":66,\"service_tier\":\"standard\"}}"
