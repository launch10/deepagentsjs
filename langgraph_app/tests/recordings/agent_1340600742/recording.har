            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_012kYpU32F8axXyT5AfkV4Gx\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Descriptions are the text lines that appear below your headlines in Google Ads search results. Each description can be up to 90 characters and gives you space to explain your benefits, features, and include a call-to-action. Google typically shows up to 2 description lines per ad, so they're your chance to expand on what makes your offer compelling and convince people to click.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2454,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":83,\"service_tier\":\"standard\"}}"
