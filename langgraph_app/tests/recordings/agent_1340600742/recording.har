        "response": {
          "bodySize": 1507,
          "content": {
            "mimeType": "application/json",
            "size": 1507,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01J2zoFax1rnYrZphMaDy9cH\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Let's start building your ad! I drafted a few headlines and descriptions that meet Google's requirements. Google will mix and match them to find what performs best. We can tailor them together to make them feel just right for you.\\n\\n```json\\n{\\n  \\\"headlines\\\": [\\n    \\\"Scheduling Made Simple\\\",\\n    \\\"Find Meeting Times Instantly\\\",\\n    \\\"Stop Endless Scheduling Threads\\\",\\n    \\\"Calendar Sync for Remote Teams\\\",\\n    \\\"Meeting Times in Seconds\\\",\\n    \\\"Distributed Teams Love Us\\\"\\n  ],\\n  \\\"descriptions\\\": [\\n    \\\"Connect calendars, set preferences, done. We find times that work for everyone across time zones instantly.\\\",\\n    \\\"2,000+ teams cut coordination time by 80%. Save 15 hours weekly on scheduling. Try free today.\\\",\\n    \\\"Tired of Slack threads about meeting times? Let us handle it. Your team just clicks yes.\\\",\\n    \\\"Optimal meeting times suggested automatically. Works across all time zones. Get started free now.\\\"\\n  ]\\n}\\n```\\n\\nWhat do you think? Feel free to let me know which headlines and descriptions resonate with you, or if you'd like me to adjust anything!\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2728,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":261,\"service_tier\":\"standard\"}}"
