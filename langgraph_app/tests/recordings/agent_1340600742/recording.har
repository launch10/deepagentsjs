            "size": 1065,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01V3hW1HVyPgEeY22FttVCke\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"I appreciate the question, but I don't have information about your specific account status or deployment timeline. That depends on a few factors:\\n\\n**Google Ads typically go live within 24 hours** after you submit them for review, though they can sometimes be approved faster. Google reviews all ads to ensure they comply with their policies.\\n\\nTo check your ad status, you can log into your Google Ads account and look at the \\\"Ads & extensions\\\" section—it will show you whether your ads are \\\"Approved,\\\" \\\"Under review,\\\" or if there are any issues that need fixing.\\n\\nIs there anything else about setting up your ads campaign that I can help with?\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1662,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":142,\"service_tier\":\"standard\"}}"
