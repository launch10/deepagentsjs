            "mimeType": "application/json",
            "size": 1486,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_014AGaJKKGs96eqa1oqaHBU9\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Let's start building your ad! I drafted a few headlines and descriptions that meet Google's requirements.\\n\\nGoogle will mix and match them to find what performs best. We can tailor them together to make them feel just right for you.\\n\\n```json\\n{\\n  \\\"headlines\\\": [\\n    \\\"Stop Endless Scheduling Threads\\\",\\n    \\\"Meeting Times in Seconds\\\",\\n    \\\"Scheduling Across Time Zones\\\",\\n    \\\"80% Less Coordination Time\\\",\\n    \\\"Your Team's Calendar Synced\\\",\\n    \\\"Find Meeting Times Instantly\\\"\\n  ],\\n  \\\"descriptions\\\": [\\n    \\\"Connect calendars, set preferences, done. We suggest optimal times across all time zones instantly. Your team just clicks yes.\\\",\\n    \\\"Trusted by 2,000+ distributed teams. Cut meeting coordination by 80%. Save 15 hours weekly on scheduling. Get started free.\\\",\\n    \\\"Tired of Slack threads about 'when works?' Our AI finds times that work for everyone. No more back-and-forth. Try it today.\\\",\\n    \\\"Stop wasting time coordinating meetings. Automated scheduling for remote teams. Works across continents. See results in days.\\\"\\n  ]\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1277,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":265,\"service_tier\":\"standard\"}}"
