 are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"idea\\\\\\\",\\\\n          \\\\\\\"audience\\\\\\\",\\\\n          \\\\\\\"solution\\\\\\\",\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"human\\\\\\\"\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n        \\\\\\\"tool_calls\\\\\\\": [],\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"d2a51589-2633-4aa6-8d17-7129c3a54ae7\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"d2a51589-2633-4aa6-8d17-7129c3a54ae7\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"idea\\\\\\\",\\\\n          \\\\\\\"audience\\\\\\\",\\\\n          \\\\\\\"solution\\\\\\\",\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"ai\\\\\\\",\\\\n      \\\\\\\"tool_calls\\\\\\\": [],\\\\n      \\\\\\\"invalid_tool_calls\\\\\\\": []\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host