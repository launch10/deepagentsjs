        "response": {
          "bodySize": 799,
          "content": {
            "mimeType": "application/json",
            "size": 799,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01ATjCkk62yeukHkA59skTeK\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"After you launch your Google Ads campaign, you'll be able to measure the results and see how people respond to your business idea! You'll get data on clicks, impressions, and conversions to understand if there's real demand for what you're offering. Then you can iterate based on what you learn—refining your ads, landing page, or even your business idea itself to find what actually works.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1024,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":86,\"service_tier\":\"standard\"}}"
