ace\\\\\\\": [\\\\n            \\\\\\\"langchain_core\\\\\\\",\\\\n            \\\\\\\"messages\\\\\\\"\\\\n          ],\\\\n          \\\\\\\"id\\\\\\\": \\\\\\\"876e9362-e367-4999-8332-d75596ac7338\\\\\\\",\\\\n          \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\\\\\n            \\\\\\\",\\\\n          \\\\\\\"additional_kwargs\\\\\\\": {\\\\n            \\\\\\\"topics\\\\\\\": [\\\\n              \\\\\\\"idea\\\\\\\",\\\\n              \\\\\\\"solution\\\\\\\"\\\\n            ]\\\\n          },\\\\n          \\\\\\\"response_metadata\\\\\\\": {}\\\\n        },\\\\n        \\\\\\\"lc_namespace\\\\\\\": [\\\\n          \\\\\\\"langchain_core\\\\\\\",\\\\n          \\\\\\\"messages\\\\\\\"\\\\n        ],\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"876e9362-e367-4999-8332-d75596ac7338\\\\\\\",\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Friend of the Pod has over 100+ filters to find the perfect guest for your show.\\\\\\\\n                We use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                We also use AI to match hosts and guests based on their content, audience, and goals.\\\\\\\\n                But what sets us apart is that we've trained proprietary models on messages that \\\\\\\\n                successful podcast hosts receive. We use this data to filter out pitches that \\\\\\\\n                are predicted to not be a good fit for your show.\\\\