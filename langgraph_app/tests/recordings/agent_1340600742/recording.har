\\\n        },\\\\n        \\\\\\\"response_metadata\\\\\\\": {}\\\\n      }\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n        \\\\\\\"tool_calls\\\\\\\": [],\\\\n        \\\\\\\"invalid_tool_calls\\\\\\\": [],\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"619da232-c8cc-4d1f-9444-10d8353314c8\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"619da232-c8cc-4d1f-9444-10d8353314c8\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"That's awesome! And what about your social proof?\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"ai\\\\\\\",\\\\n      \\\\\\\"tool_calls\\\\\\\": [],\\\\n      \\\\\\\"invalid_tool_calls\\\\\\\": []\\\\n    },\\\\n    {\\\\n      \\\\\\\"lc_serializable\\\\\\\": true,\\\\n      \\\\\\\"lc_kwargs\\\\\\\": {\\\\n        \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n        \\\\\\\"additional_kwargs\\\\\\\": {},\\\\n        \\\\\\\"response_metadata\\\\\\\": {},\\\\n        \\\\\\\"id\\\\\\\": \\\\\\\"ee8ef2e4-7da1-4b2e-a08a-72e2b65d011c\\\\\\\"\\\\n      },\\\\n      \\\\\\\"lc_namespace\\\\\\\": [\\\\n        \\\\\\\"langchain_core\\\\\\\",\\\\n        \\\\\\\"messages\\\\\\\"\\\\n      ],\\\\n      \\\\\\\"id\\\\\\\": \\\\\\\"ee8ef2e4-7da1-4b2e-a08a-72e2b65d011c\\\\\\\",\\\\n      \\\\\\\"content\\\\\\\": \\\\\\\"Over 10k creators use Friend of the Pod to find guests for their shows.\\\\\\\\n    Real case: Host found 3 guests in 10 minutes instead of 5 hours of manual outreach, leading to 2 viral episodes. As the founder of the company, I used to work at Spotify and Apple Podcasts, so I've seen first hand what makes a guest a good fit for a show, and I understand the industry.\\\\\\\",\\\\n      \\\\\\\"additional_kwargs\\\\\\\": {\\\\n        \\\\\\\"topics\\\\\\\": [\\\\n          \\\\\\\"socialProof\\\\\\\"\\\\n        ]\\\\n      },\\\\n      \\\\\\\"response_metadata\\\\\\\": {},\\\\n      \\\\\\\"type\\\\\\\": \\\\\\\"human\\\\\\\"\\\\n    }\\\\n  ]\\\\n}\\\"</message>\\n</chat-history>\\n        \\n        <task>\\n            Explain the user's options to them, or answer any questions they may have\\n            about the process.\\n\\n            1. Brand Personalization (optional)\\n            2. Build My Site button\\n        \\n            Make it clear both paths are valid.\\n        \\n            Output JSON: {\\n                \\\"text\\\": \\\"Guide the user to the next step\\\",\\n                \\\"examples\\\": [\\\"Option 1 explanation\\\", \\\"Option 2 explanation\\\"], // Optional, only if necessary\\n                \\\"conclusion\\\": \\\"Clearly state the next step\\\" // Optional, only if necessary\\n            }\\n        </task>\\n    \"}"
