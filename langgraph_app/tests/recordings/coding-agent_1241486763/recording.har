el: \\\"Saved per week per team\\\"\\n  }\\n];\\n\\nconst testimonials = [\\n  {\\n    quote: \\\"We went from endless email chains across three continents to one-click scheduling. Our engineering team now spends those saved hours actually building product instead of playing calendar Tetris.\\\",\\n    author: \\\"Sarah Chen\\\",\\n    title: \\\"VP of Operations at TechCorp\\\"\\n  },\\n  {\\n    quote: \\\"The timezone confusion alone was costing us deals. Now our sales team books client calls instantly, regardless of where they're located. It's like having a personal assistant for every rep.\\\",\\n    author: \\\"Marcus Rodriguez\\\",\\n    title: \\\"Head of Sales at CloudScale\\\"\\n  },\\n  {\\n    quote: \\\"I used to dread scheduling our weekly all-hands with team members in Tokyo, London, and San Francisco. Now it takes 30 seconds, and everyone actually shows up because the time works for them.\\\",\\n    author: \\\"Priya Patel\\\",\\n    title: \\\"Director of People Ops at DataFlow\\\"\\n  }\\n];\\n\\nexport function SocialProof() {\\n  return (\\n    <section className=\\\"py-20 md:py-32 bg-background\\\">\\n      <div className=\\\"container mx-auto px-4\\\">\\n        <div className=\\\"max-w-3xl mx-auto text-center mb-16\\\">\\n          <h2 className=\\\"text-3xl md:text-5xl font-bold text-foreground mb-4\\\">\\n            Trusted by Teams Who Value Their Time\\n          </h2>\\n        </div>\\n\\n        {/* Statistics */}\\n        <div className=\\\"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-20\\\">\\n          {statistics.map((stat, index) => (\\n            <div \\n              key={index} \\n              className=\\\"text-center p-8 bg-primary/5 rounded-lg border-2 border-primary/20 hover:border-primary/40 transition-colors\\\"\\n            >\\n              <div className=\\\"text-4xl md:text-5xl font-bold text-primary mb-2\\\">\\n                {stat.metric}\\n              </div>\\n              <div className=\\\"text-muted-foreground font-medium\\\">\\n                {stat.label}\\n              </div>\\n            </div>\\n          ))}\\n        </div>\\n\\n        {/* Testimonials */}\\n        <div className=\\\"grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto\\\">\\n          {testimonials.map((testimonial, index) => (\\n            <Card \\n              key={index} \\n              className=\\\"border-2 hover:shadow-lg transition-all duration-300 bg-card\\\"\\n            >\\n              <CardContent className=\\\"p-6\\\">\\n                <Quote className=\\\"w-10 h-10 text-secondary mb-4 opacity-50\\\" />\\n                <p className=\\\"text-card-foreground mb-6 leading-relaxed\\\">\\n                  \\\"{testimonial.quote}\\\"\\n                </p>\\n                <div className=\\\"border-t-2 border-border pt-4\\\">\\n                  <div className=\\\"font-bold text-card-foreground\\\">\\n                    {testimonial.author}\\n                  </div>\\n                  <div className=\\\"text-sm text-card-foreground-muted\\\">\\n                    {testimonial.title}\\n                  </div>\\n                </div>\\n              </CardContent>\\n            </Card>\\n          ))}\\n        </div>\\n\\n        {/* Trust badges */}\\n        <div className=\\\"mt-16 flex flex-wrap justify-center items-center gap-8 opacity-60\\\">\\n          <div className=\\\"text-muted-foreground font-semibold text-lg\\\">Used by teams at:</div>\\n          <div className=\\\"flex flex-wrap justify-center gap-8\\\">\\n            <div className=\\\"text-muted-foreground font-bold text-xl\\\">TechCorp</div>\\n            <div className=\\\"text-muted-foreground font-bold text-xl\\\">CloudScale</div>\\n            <div className=\\\"text-muted-foreground font-bold text-xl\\\">DataFlow</div>\\n          </div>\\n        </div>\\n      </div>\\n    </section>\\n  );\\n}\"}}]},{\"role\":\"user\",\"content\":[{\"type\":\"tool_result\",\"content\":\"S