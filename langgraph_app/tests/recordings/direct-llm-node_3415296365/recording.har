            "text": "{\"model\":\"claude-sonnet-4-5\",\"temperature\":0,\"stream\":false,\"max_tokens\":2048,\"thinking\":{\"type\":\"disabled\"},\"messages\":[{\"role\":\"user\",\"content\":\"Test reasoning tokens\"}]}"
