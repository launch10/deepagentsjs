ct';\\n     2\\timport { Button } from '@/components/ui/button';\\n     3\\timport { Input } from '@/components/ui/input';\\n     4\\timport { ArrowRight } from 'lucide-react';\\n     5\\t\\n     6\\tconst validationFeed = [\\n     7\\t  { location: \\\"Austin, TX\\\", idea: \\\"B2B recruiting platform\\\", conversion: \\\"12.4%\\\" },\\n     8\\t  { location: \\\"London, UK\\\", idea: \\\"AI writing assistant\\\", conversion: \\\"8.7%\\\" },\\n     9\\t  { location: \\\"Berlin, DE\\\", idea: \\\"Fitness subscription box\\\", conversion: \\\"15.2%\\\" },\\n    10\\t  { location: \\\"Toronto, CA\\\", idea: \\\"Remote team analytics\\\", conversion: \\\"11.1%\\\" },\\n    11\\t  { location: \\\"Sydney, AU\\\", idea: \\\"Sustainable fashion marketplace\\\", conversion: \\\"9.8%\\\" },\\n    12\\t  { location: \\\"San Francisco, CA\\\", idea: \\\"Developer productivity tool\\\", conversion: \\\"18.3%\\\" },\\n    13\\t  { location: \\\"New York, NY\\\", idea: \\\"Pet care subscription\\\", conversion: \\\"7.2%\\\" },\\n    14\\t  { location: \\\"Seattle, WA\\\", idea: \\\"No-code automation\\\", conversion: \\\"14.6%\\\" },\\n    15\\t];\\n    16\\t\\n    17\\tconst LiveValidationTicker = () => {\\n    18\\t  const [currentIndex, setCurrentIndex] = useState(0);\\n    19\\t  const [isVisible, setIsVisible] = useState(true);\\n    20\\t\\n    21\\t  useEffect(() => {\\n    22\\t    const interval = setInterval(() => {\\n    23\\t      setIsVisible(false);\\n    24\\t      setTimeout(() => {\\n    25\\t        setCurrentIndex((prev) => (prev + 1) % validationFeed.length);\\n    26\\t        setIsVisible(true);\\n    27\\t      }, 500);\\n    28\\t    }, 4000);\\n    29\\t    return () => clearInterval(interval);\\n    30\\t  }, []);\\n    31\\t\\n    32\\t  const current = validationFeed[currentIndex];\\n    33\\t  \\n    34\\t  return (\\n    35\\t    <div className=\\\"bg-primary/5 border border-primary/20 rounded-full px-4 py-2 inline-flex items-center gap-2\\\">\\n    