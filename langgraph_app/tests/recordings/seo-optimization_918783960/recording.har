t            </p>\\n    18\\t          </div>\\n    19\\t          <div>\\n    20\\t            <h4 className=\\\"font-semibold mb-4\\\">Product</h4>\\n    21\\t            <ul className=\\\"space-y-2 text-sm text-muted-foreground\\\">\\n    22\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Features</a></li>\\n    23\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Pricing</a></li>\\n    24\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Methodology</a></li>\\n    25\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">API</a></li>\\n    26\\t            </ul>\\n    27\\t          </div>\\n    28\\t          <div>\\n    29\\t            <h4 className=\\\"font-semibold mb-4\\\">Resources</h4>\\n    30\\t            <ul className=\\\"space-y-2 text-sm text-muted-foreground\\\">\\n    31\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Blog</a></li>\\n    32\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Playbooks</a></li>\\n    33\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Case Studies</a></li>\\n    34\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Help Center</a></li>\\n    35\\t            </ul>\\n    36\\t          </div>\\n    37\\t          <div>\\n    38\\t            <h4 className=\\\"font-semibold mb-4\\\">Company</h4>\\n    39\\t            <ul className=\\\"space-y-2 text-sm text-muted-foreground\\\">\\n    40\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">About</a></li>\\n    41\\t              <li><a href=\\\"#\\\" className=\\\"hover:text-foreground transition-colors\\\">Careers</a></li>\\n    42\\t              <li><a href=\\\"