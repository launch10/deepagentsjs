            "size": 335,
            "text": "{\"id\":\"34894348-9c36-4b84-aa1c-e8eb98b47cf5\",\"results\":[{\"index\":0,\"relevance_score\":0.82560414},{\"index\":1,\"relevance_score\":0.37325934},{\"index\":2,\"relevance_score\":0.35133386},{\"index\":3,\"relevance_score\":0.25294688},{\"index\":6,\"relevance_score\":0.23887892}],\"meta\":{\"api_version\":{\"version\":\"2\"},\"billed_units\":{\"search_units\":1}}}"
