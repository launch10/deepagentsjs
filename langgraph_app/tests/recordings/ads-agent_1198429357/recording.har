            "mimeType": "application/json",
            "size": 1082,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01LCUXJp6Uxhxt1PhZtBnV9s\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Next, let's spell out some unique features of your business.\\n\\nThis helps your ad take up more real estate, and gives your users more reasons to click. I filled in a few ideas to help get us started.\\n\\n```json\\n{\\n  \\\"callouts\\\": [\\n    \\\"80% Less Scheduling Time\\\",\\n    \\\"Works Across Time Zones\\\",\\n    \\\"2,000+ Teams Trust Us\\\",\\n    \\\"Free Trial, No Credit Card\\\",\\n    \\\"Instant Meeting Suggestions\\\",\\n    \\\"Integrates With All Calendars\\\"\\n  ],\\n  \\\"structuredSnippets\\\": {\\n    \\\"category\\\": \\\"Service catalog\\\",\\n    \\\"details\\\": [\\n      \\\"Automatic Time Zone Matching\\\",\\n      \\\"Calendar Integration\\\",\\n      \\\"Team Availability Sharing\\\"\\n    ]\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1634,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":185,\"service_tier\":\"standard\"}}"
