            "size": 335,
            "text": "{\"id\":\"7fa45997-05b2-4e16-b1ce-ce3eaa577f5a\",\"results\":[{\"index\":0,\"relevance_score\":0.7300017},{\"index\":2,\"relevance_score\":0.3229961},{\"index\":4,\"relevance_score\":0.121487826},{\"index\":5,\"relevance_score\":0.112006456},{\"index\":7,\"relevance_score\":0.11021253}],\"meta\":{\"api_version\":{\"version\":\"2\"},\"billed_units\":{\"search_units\":1}}}"
