            "mimeType": "application/json",
            "size": 743,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_013LBXuGSxbNoJdoACBo4WQr\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Yes, you can absolutely change your ads after they're live! When you edit your headlines or descriptions, the changes will sync to Google Ads, though Google may need some time to re-learn which combinations perform best. Small, focused changes work better than rewriting everything at once unless you're repositioning your entire offer.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1312,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":69,\"service_tier\":\"standard\"}}"
