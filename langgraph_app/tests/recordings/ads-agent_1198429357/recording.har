        "response": {
          "bodySize": 731,
          "content": {
            "mimeType": "application/json",
            "size": 731,
            "text": "{\"model\":\"claude-sonnet-4-5-20250929\",\"id\":\"msg_01RpS9QSpz21eR4ZXuULqiwu\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Yes, you can edit your Google Ads campaign after it's live! You can pause your ads at any time, make changes to your headlines, descriptions, keywords, or budget, and then resume running them. This flexibility allows you to test and optimize your campaign based on what's working best to drive traffic to your landing page.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1107,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":70,\"service_tier\":\"standard\"}}"
