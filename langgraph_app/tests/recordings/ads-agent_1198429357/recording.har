          "content": {
            "mimeType": "application/json",
            "size": 749,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01LYGWfpSequUTsWZ7erVZBp\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"I don't have specific information about your account setup timeline, but typically Google Ads campaigns go live within a few hours to 1 business day after you create and submit them for review. The exact timing depends on whether your ads need additional review or if they're approved immediately based on your account history and ad content.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1027,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":68,\"service_tier\":\"standard\"}}"
