            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01M2oMLwPj8n5tECGBDQPQud\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"```json\\n{\\n  \\\"keywords\\\": [\\n    \\\"schedule meetings across time zones\\\",\\n    \\\"best calendar scheduling app\\\",\\n    \\\"team availability scheduling tool\\\"\\n  ]\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2405,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":45,\"service_tier\":\"standard\"}}"
