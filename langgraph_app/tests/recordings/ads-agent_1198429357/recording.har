        "response": {
          "bodySize": 807,
          "content": {
            "mimeType": "application/json",
            "size": 807,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01EGT4vripJSx57XxL1CGQEc\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"After you launch your Google Ads campaign, you'll be able to measure the results and see how people respond to your business idea! You'll get data on clicks, impressions, and conversions to understand if people are actually excited about what you're offering. Then you can iterate based on what you learn—refining your ads, landing page, or even your core business idea—to find what really works.\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1024,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":87,\"service_tier\":\"standard\"}}"
