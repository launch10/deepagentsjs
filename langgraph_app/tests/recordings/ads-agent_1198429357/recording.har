            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01DNHRd96URnismDchqQ83T8\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Next, let's spell out some unique features of your business.\\n\\nThis helps your ad take up more real estate, and gives your users more reasons to click. I filled in a few ideas to help get us started.\\n\\n```json\\n{\\n  \\\"callouts\\\": [\\n    \\\"80% Less Coordination Time\\\",\\n    \\\"Works Across All Time Zones\\\",\\n    \\\"Connect Any Calendar App\\\",\\n    \\\"Free to Get Started\\\",\\n    \\\"Used by 2,000+ Teams\\\",\\n    \\\"Instant Meeting Suggestions\\\"\\n  ],\\n  \\\"structuredSnippets\\\": {\\n    \\\"category\\\": \\\"Features\\\",\\n    \\\"details\\\": [\\n      \\\"Automatic Time Zone Detection\\\",\\n      \\\"One-Click Calendar Integration\\\",\\n      \\\"Smart Availability Preferences\\\"\\n    ]\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1645,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":182,\"service_tier\":\"standard\"}}"
