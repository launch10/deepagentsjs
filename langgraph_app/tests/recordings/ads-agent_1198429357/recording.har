            "text": "{\"id\":\"8069c5ca-31c1-4518-ba21-525c3b8573d9\",\"results\":[{\"index\":0,\"relevance_score\":0.09871195},{\"index\":9,\"relevance_score\":0.060246922},{\"index\":1,\"relevance_score\":0.042202137},{\"index\":3,\"relevance_score\":0.03745702},{\"index\":5,\"relevance_score\":0.032889787}],\"meta\":{\"api_version\":{\"version\":\"2\"},\"billed_units\":{\"search_units\":1}}}"
