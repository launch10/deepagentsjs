            "size": 1183,
            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01Qj6AkfNUQLYB6SiLYkFq3R\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Here are some fresh suggestions:\\n\\n```json\\n{\\n  \\\"headlines\\\": [\\n    \\\"End Calendar Chaos Today\\\",\\n    \\\"Your Team's Time Zone Fix\\\",\\n    \\\"Instant Meeting Consensus\\\",\\n    \\\"Never Ask 'When Works?' Again\\\",\\n    \\\"Sync Global Teams Instantly\\\",\\n    \\\"Meeting Times That Just Work\\\"\\n  ],\\n  \\\"descriptions\\\": [\\n    \\\"Skip the back-and-forth emails. One click schedules across all time zones. Your team approves in seconds.\\\",\\n    \\\"Distributed teams deserve better. Automatic scheduling that respects everyone's availability. Try free.\\\",\\n    \\\"Tired of coordination overload? We handle the complexity. Your team just confirms and moves on.\\\",\\n    \\\"Real-time availability matching across continents. No more guessing. No more delays. Schedule now.\\\"\\n  ]\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":2127,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":192,\"service_tier\":\"standard\"}}"
