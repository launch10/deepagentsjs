            "text": "{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01AkKkKw8isYd6cTsxtDVcjc\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Next, let's spell out some unique features of your business.\\n\\nThis helps your ad take up more real estate, and gives your users more reasons to click. I filled in a few ideas to help get us started.\\n\\n```json\\n{\\n  \\\"callouts\\\": [\\n    \\\"80% Less Scheduling Time\\\",\\n    \\\"Works Across All Time Zones\\\",\\n    \\\"One-Click Meeting Confirmation\\\",\\n    \\\"Integrates With Your Calendar\\\",\\n    \\\"Used by 2,000+ Teams\\\",\\n    \\\"Free 14-Day Trial\\\"\\n  ],\\n  \\\"structuredSnippets\\\": {\\n    \\\"category\\\": \\\"Services\\\",\\n    \\\"details\\\": [\\n      \\\"Automatic Time Zone Matching\\\",\\n      \\\"Team Availability Sync\\\",\\n      \\\"Instant Meeting Suggestions\\\"\\n    ]\\n  }\\n}\\n```\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1205,\"cache_creation_input_tokens\":0,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":188,\"service_tier\":\"standard\"}}"
