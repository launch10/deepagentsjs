        "request": {
          "bodySize": 72786,
          "cookies": [],
          "headers": [
            {
              "name": "accept",
              "value": "application/json"
            },
            {
              "name": "anthropic-dangerous-direct-browser-access",
              "value": "true"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "content-type",
              "value": "application/json"
            },
            {
              "name": "user-agent",
              "value": "Anthropic/JS 0.65.0"
            },
            {
              "name": "x-stainless-lang",
              "value": "js"
            },
            {
              "name": "x-stainless-package-version",
              "value": "0.65.0"
            },
            {
