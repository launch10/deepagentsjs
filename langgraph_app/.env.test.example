# Launch10 Test Environment Configuration
#
# Service ports and URLs are managed by config/services.sh
# When running tests via bin/test, these values are set automatically:
#   RAILS_PORT=3001
#   RAILS_API_URL=http://localhost:3001
#   LANGGRAPH_PORT=4001
#
# This file provides defaults that work when not using bin/test.

LANGSMITH_TRACING=false
LANGSMITH_PROJECT=default
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your-langsmith-api-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/launch10_test
REDIS_URL=redis://localhost:6379
VITE_LOG_LEVEL=debug
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
LLM_PAID=paid
#LLM_SPEED=fast

# Service configuration - matches test ports from config/services.sh
RAILS_PORT=3001
RAILS_API_URL=http://localhost:3001
ALLOWED_HOSTS=localhost:3001,127.0.0.1:3001

JWT_SECRET=your-jwt-secret-min-64-chars
USE_CACHE=false
CACHE_TTL=86400
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_HOST=https://cloud.langfuse.com
NODE_ENV=test
