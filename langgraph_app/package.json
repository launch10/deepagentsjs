{
  "name": "example_langgraph_app",
  "description": "Example LangGraph App",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">= 24.1.0"
  },
  "scripts": {
    "dev": "tsx watch ./server.ts",
    "dev:debug": "NODE_OPTIONS=--inspect-brk langgraph dev -n 1",
    "test": "vitest tests/prompts tests/nodes tests/tools --run --no-file-parallelism",
    "test:watch": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:types": "vitest --typecheck.only",
    "eval": "NODE_ENV=test evalite watch",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc",
    "repo:size": "sh scripts/repo-size.sh",
    "preview": "pnpm run build && pnpm run start",
    "prompt:gallery": "vite --config vite.prompts.config.ts",
    "repl": "tsx scripts/repl.ts",
    "db:reflect": "tsx scripts/db/preserve-relations.ts",
    "edit:scenario": "NODE_ENV=test tsx scripts/scenarios/edit-scenario.ts",
    "create:scenario": "NODE_ENV=test tsx scripts/scenarios/create-scenario.ts",
    "edit:snapshot": "NODE_ENV=test tsx scripts/scenarios/edit-snapshot.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "langgraph-ai-sdk": "^1.0.15",
    "@launch10/shared": "workspace:*",
    "@ai-sdk/openai": "^1.3.22",
    "@langchain/anthropic": "^0.3.33",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/groq": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/ollama": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "change-case": "^5.4.4",
    "chokidar": "^4.0.3",
    "chroma-js": "^3.1.2",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "diff": "^7.0.0",
    "dotenv": "^16.5.0",
    "dotenv-expand": "^12.0.2",
    "drizzle-kit": "^0.31.1",
    "drizzle-orm": "^0.43.1",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.7.1",
    "execa": "^9.5.2",
    "fast-json-stable-stringify": "^2.1.0",
    "hono": "^4.7.10",
    "ioredis": "^5.6.1",
    "isbot": "^5.1.27",
    "istextorbinary": "^9.5.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^1.0.0",
    "langsmith": "^0.3.25",
    "lodash": "^4.17.21",
    "lucide-react": "^0.544.0",
    "micromatch": "^4.0.8",
    "minimatch": "^10.0.1",
    "next-mdx-remote": "^5.0.0",
    "pg": "^8.15.6",
    "playwright": "^1.55.1",
    "pnpm": "^10.10.0",
    "postgres": "^3.4.7",
    "random-words": "^2.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.1",
    "react-server-dom-webpack": "^19.1.1",
    "react-toastify": "^11.0.5",
    "readdirp": "^4.1.2",
    "redis-connection-pool": "^4.0.1",
    "rollbar": "^2.26.4",
    "shiki": "^3.4.0",
    "tsx": "^4.20.6",
    "uuid": "^11.1.0",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-optimize-css-modules": "^1.2.0",
    "xml-formatter": "^3.6.6",
    "yargs": "^17.7.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@faker-js/faker": "^10.0.0",
    "@pollyjs/adapter-fetch": "^6.0.7",
    "@pollyjs/adapter-node-http": "^6.0.6",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@tailwindcss/postcss": "^4.1.5",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20.19.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoevals": "^0.0.131",
    "chalk": "^5.6.2",
    "commander": "^14.0.0",
    "eslint": "^9",
    "evalite": "^0.11.5",
    "expect-type": "^1.2.2",
    "fast-glob": "^3.3.3",
    "fishery": "^2.3.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "node-fetch": "^3.3.2",
    "type-fest": "^5.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.46.0",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.1"
  }
}