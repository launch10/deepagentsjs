{
  "name": "@nichefinder/langgraph",
  "description": "Nichefinder",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=20.16.0"
  },
  "scripts": {
    "dev": "tsx ./server.mts",
    "dev:debug": "NODE_OPTIONS=--inspect-brk langgraph dev -n 1",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc",
    "preview": "pnpm run build && pnpm run start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:drop": "drizzle-kit drop",
    "db:seed": "tsx --inspect-brk db/seed.ts",
    "debug:graph": "tsx debug-graph.ts",
    "debug:update": "tsx --inspect-brk debug-update-graph.ts",
    "debug:create-page": "tsx --inspect-brk debug-create-page.ts",
    "debug:create-section": "tsx --inspect-brk debug-create-section.ts",
    "debug:script": "tsx --inspect-brk debug-script.ts",
    "debug:mapreduce": "tsx --inspect-brk debug-mapreduce.ts",
    "debug:fixbug": "tsx --inspect-brk debug-fixbug.ts",
    "debug:update-styles": "tsx --inspect-brk debug-update-styles.ts",
    "debug:build-tasks": "tsx --inspect-brk debug-build-tasks.ts",
    "debug:query-icons": "tsx debug-query-icons.ts",
    "debug:save": "tsx --inspect-brk scripts/testSaveProject.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
