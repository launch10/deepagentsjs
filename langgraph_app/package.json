{
  "name": "example_langgraph_app",
  "description": "Example LangGraph App",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">= 24.1.0"
  },
  "scripts": {
    "dev": "tsx watch --watch-path=./app --watch-path=./server.ts --watch-path=../shared ./server.ts",
    "worker": "tsx ./app/workers/documentExtractionWorker.ts",
    "worker:dev": "tsx watch --watch-path=./app --watch-path=../shared ./app/workers/documentExtractionWorker.ts",
    "dev:debug": "NODE_OPTIONS=--inspect-brk tsx ./server.ts",
    "test": "bin/test",
    "test:watch": "bin/test --watch",
    "test:with-rails": "bin/test --with-rails",
    "test:debug": "NODE_OPTIONS=--inspect-brk bin/test",
    "test:vitest": "vitest tests/tests --run --no-file-parallelism",
    "test:vitest:watch": "vitest",
    "test:types": "vitest --typecheck.only",
    "services": "bin/services",
    "services:status": "LAUNCH10_ENV=test bin/services status",
    "services:cleanup": "LAUNCH10_ENV=test bin/services cleanup",
    "services:start-rails": "LAUNCH10_ENV=test bin/services start-rails",
    "eval": "NODE_ENV=test evalite watch",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc",
    "repo:size": "sh scripts/repo-size.sh",
    "preview": "pnpm run build && pnpm run start",
    "prompt:gallery": "vite --config vite.prompts.config.ts",
    "repl": "tsx scripts/repl.ts",
    "db:reflect": "tsx scripts/db/preserve-relations.ts",
    "edit:scenario": "NODE_ENV=test tsx scripts/scenarios/edit-scenario.ts",
    "create:scenario": "NODE_ENV=test tsx scripts/scenarios/create-scenario.ts",
    "edit:snapshot": "NODE_ENV=test tsx scripts/scenarios/edit-snapshot.ts",
    "export-website": "tsx scripts/export-website.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@hono/node-server": "^1.19.7",
    "@langchain/anthropic": "^0.3.33",
    "@langchain/community": "^1.0.7",
    "@langchain/core": "^1.1.18",
    "@langchain/groq": "^1.0.2",
    "@langchain/langgraph": "1.1.3",
    "@langchain/langgraph-checkpoint": "^1.0.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/langgraph-sdk": "^1.3.1",
    "@langchain/ollama": "^1.0.3",
    "@langchain/openai": "^1.1.3",
    "@langchain/textsplitters": "^1.0.1",
    "@launch10/shared": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/wait-on": "^5.3.4",
    "bullmq": "^5.65.1",
    "change-case": "^5.4.4",
    "chokidar": "^4.0.3",
    "chroma-js": "^3.2.0",
    "cohere-ai": "^7.20.0",
    "cookie": "^1.1.1",
    "date-fns": "^4.1.0",
    "deepagents": "^1.6.2",
    "diff": "^7.0.0",
    "dotenv": "^16.6.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.43.1",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.7.1",
    "execa": "^9.6.1",
    "fast-json-stable-stringify": "^2.1.0",
    "hono": "^4.10.8",
    "ioredis": "^5.8.2",
    "isbot": "^5.1.32",
    "istextorbinary": "^9.5.0",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.1.5",
    "langgraph-ai-sdk": "workspace:*",
    "langgraph-ai-sdk-types": "workspace:*",
    "langsmith": "^0.3.84",
    "lodash": "^4.17.21",
    "lucide-react": "^0.544.0",
    "micromatch": "^4.0.8",
    "minimatch": "^10.1.1",
    "next-mdx-remote": "^5.0.0",
    "openapi-fetch": "^0.15.0",
    "pg": "^8.16.3",
    "playwright": "^1.57.0",
    "pnpm": "^10.25.0",
    "postgres": "^3.4.7",
    "random-words": "^2.0.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-server-dom-webpack": "^19.2.1",
    "react-toastify": "^11.0.5",
    "readdirp": "^4.1.2",
    "redis-connection-pool": "^4.0.1",
    "rollbar": "^2.26.5",
    "shiki": "^3.19.0",
    "tsx": "^4.21.0",
    "uuid": "^11.1.0",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vite-plugin-optimize-css-modules": "^1.2.0",
    "xml-formatter": "^3.6.7",
    "yargs": "^17.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.1.0",
    "@pollyjs/adapter-fetch": "^6.0.7",
    "@pollyjs/adapter-node-http": "^6.0.6",
    "@pollyjs/core": "^6.0.6",
    "@pollyjs/persister-fs": "^6.0.6",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.21",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^20.19.26",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoevals": "^0.0.131",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "evalite": "^0.11.6",
    "expect-type": "^1.3.0",
    "fast-glob": "^3.3.3",
    "fishery": "^2.4.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "node-fetch": "^3.3.2",
    "prettier": "^3.7.4",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
