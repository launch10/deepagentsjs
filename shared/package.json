{
  "name": "@launch10/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "fast-json-stable-stringify": "^2.1.0",
    "langgraph-ai-sdk-react": "^1.0.32",
    "langgraph-ai-sdk-types": "^1.0.32",
    "uuid": "^11.1.0",
    "zod": "^3.24.4",
    "zod-to-json-schema": "^3.24.6",
    "openapi-fetch": "^0.15.0"
  },
  "peerDependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "peerDependenciesMeta": {
    "jsonwebtoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/uuid": "^10.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "type-fest": "^5.2.0",
    "typescript": "^5.5.4",
    "openapi-typescript": "^7.10.1"
  },
  "scripts": {
    "api:generate": "openapi-typescript ../rails_app/swagger/v1/swagger.yaml -o lib/api/generated/rails-api.ts --additional-properties false",
    "inertia:generate": "openapi-typescript ../rails_app/swagger/v1/inertia-props.yaml -o lib/api/generated/inertia-props.ts --additional-properties false",
    "types:generate": "pnpm run api:generate && pnpm run inertia:generate",
    "config:export": "npx tsx scripts/export-config.ts"
  }
}