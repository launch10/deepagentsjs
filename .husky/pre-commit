# Run linters and auto-fix before commit
echo "🔍 Running pre-commit checks..."
cd "$(dirname "$0")/.."

# Lint Langgraph code
cd langgraph_app
if pnpm run lint:fix && pnpm run typecheck; then
  echo "✅ Langgraph linting passed!"
else
  echo "❌ Langgraph linting failed!"
  exit 1
fi

# Lint Rails code
cd ../rails_app
if bundle exec rubocop --autocorrect-all --format simple; then
  echo "✅ Rubocop passed!"
else
  echo "❌ Rubocop failed!"
  exit 1
fi

cd ../

# Check if Rails API specs changed (triggers Swagger regeneration)
if git diff --cached --name-only | grep -q "rails_app/spec/\(requests\|api\|integration\)/"; then
  echo "1️⃣  Rails specs changed - generating Swagger documentation..."
  ./scripts/generate-docs.sh
  echo ""
  
  # Check if swagger was updated
  if ! git diff --quiet rails_app/swagger/ 2>/dev/null; then
    echo "⚠️  Warning: Swagger documentation was updated!"
    echo ""
    echo "The following files were updated:"
    git diff --name-only rails_app/swagger/ 2>/dev/null || true
    echo ""
    echo "Please review and commit these changes."
    echo ""
    exit 1
  fi
else
  echo "1️⃣  Skipping Swagger generation (no spec changes)"
fi

# Check if Swagger changed (triggers TypeScript type regeneration)
if git diff --cached --name-only | grep -q "rails_app/swagger/"; then
  echo "2️⃣  Swagger changed - generating TypeScript types..."
  ./scripts/generate-types.sh
  echo ""
  
  # Check if types were updated
  if ! git diff --quiet langgraph_app/app/lib/server/api/generated/ 2>/dev/null; then
    echo "⚠️  Warning: TypeScript types were updated!"
    echo ""
    echo "The following files were updated:"
    git diff --name-only langgraph_app/app/lib/server/api/generated/ 2>/dev/null || true
    echo ""
    echo "Please review and commit these changes."
    echo ""
    exit 1
  fi
else
  echo "2️⃣  Skipping TypeScript type generation (no swagger changes)"
fi

echo "✅ Pre-commit checks passed!"
