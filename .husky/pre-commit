#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Run linters and auto-fix before commit
echo "🔍 Running pre-commit checks..."

# Lint Rails code
cd rails_app
if bundle exec rubocop --autocorrect-all --format simple; then
  echo "✅ Rubocop passed!"
else
  echo "❌ Rubocop failed!"
  exit 1
fi

