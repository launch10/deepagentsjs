# Run linters and auto-fix before commit
echo "🔍 Running pre-commit checks..."
cd "$(dirname "$0")/.."

cd shared
pnpm run config:export

# Lint Langgraph code
cd ../langgraph_app
if pnpm run lint:fix > /dev/null 2>&1 && pnpm run typecheck > /dev/null 2>&1; then
  echo "✅ Langgraph"
else
  echo "❌ Langgraph failed - running checks to show errors:"
  pnpm run lint:fix && pnpm run typecheck
  exit 1
fi

# Lint Rails code
cd ../rails_app
if bundle exec rubocop --autocorrect-all --format simple > /dev/null 2>&1; then
  echo "✅ Rails"
else
  echo "❌ Rails failed - running rubocop to show errors:"
  bundle exec rubocop --autocorrect-all --format simple
  exit 1
fi
